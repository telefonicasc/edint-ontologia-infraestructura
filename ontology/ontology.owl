    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#intensidad</IRI>
        <Literal xml:lang="es">Intensidad o aforo, número de vehículos en unidad de tiempo (hora, día, mes año). Los habituales son hora y día.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#intensidad</IRI>
        <Literal xml:lang="en">Intensity or capacity, number of vehicles in time unit (hour, day, month, year). The usual ones are hour and day.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#intensidad</IRI>
        <Literal xml:lang="es">intensidad</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#intensidad</IRI>
        <Literal xml:lang="en">traffic intensity</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#monitorea</IRI>
        <Literal xml:lang="es">Relación del Equipo de Tráfico con el Tramo que monitorea</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#monitorea</IRI>
