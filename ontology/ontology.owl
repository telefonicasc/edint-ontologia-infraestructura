        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico</IRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#incidenciaAdjunto</IRI>
        <Literal xml:lang="es">adjunto a la incidencia</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
