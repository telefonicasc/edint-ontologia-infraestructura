        <Literal xml:lang="en">Regulated parking zone</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.linkeddata.es/datosabiertos/def/femp-base/zona#RegulatedParkingZone</IRI>
        <Literal xml:lang="es">Zona de estacionamiento regulado</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.linkeddata.es/datosabiertos/def/femp-base/zona#RegulatedZone</IRI>
        <Literal xml:lang="es">Area a la que se aplica una regulacion o normativa particular.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
