        <Literal xml:lang="es">Relación del tramo con el lugar donde se inicia el tramo.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo</IRI>
        <Literal xml:lang="en">Relationship of the section with the point where it starts.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo</IRI>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico</IRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
