    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:description"/>
        <Literal xml:lang="es">La ontología de infraestructura describe todos los conceptos relacionados con las instalaciones públicas y privadas de un municipio.  Estas incluyen aparcamientos dentro y fuera de la vía pública, bibliotecas, centros de salud, centros sociales, juzgados, comisarías, centros educativos, entre otros.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:description"/>
        <Literal xml:lang="en">The infrastructure ontology describes all concepts related to a municipality&apos;s public and private facilities. These include on-street and off-street parking, libraries, health centers, community centers, courthouses, police stations, educational centers, among others.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:license"/>
        <IRI>https://creativecommons.org/licenses/by/4.0/</IRI>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:title"/>
        <Literal xml:lang="es">Ontología de Infraestructura</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:title"/>
        <Literal xml:lang="en">The Infrastructure Ontology</Literal>
    </Annotation>
