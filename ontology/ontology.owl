        <Literal xml:lang="es">Observación realizada por un Dispositivo de Medición de Tráfico</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#ObservacionTrafico</IRI>
        <Literal xml:lang="en">Observation by a Traffic Measuring Device</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#ObservacionTrafico</IRI>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico</IRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#ObservacionTrafico</IRI>
        <Literal xml:lang="es">Observación del tráfico</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#ObservacionTrafico</IRI>
        <Literal xml:lang="en">Traffic monitoring</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico</IRI>
        <Literal xml:lang="en">Property of the Meassurement of Traffic: composition, load, occupation, intensity, level or speed.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico</IRI>
        <Literal xml:lang="es">Propiedad de la Medición de Tráfico: composición, carga, ocupación, intensidad, nivel o velocidad.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico</IRI>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico</IRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico</IRI>
        <Literal xml:lang="es">Propiedad Medición Tráfico</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico</IRI>
        <Literal xml:lang="en">Traffic meassuring property</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo</IRI>
        <Literal xml:lang="en">Section/s of a Track defined by a starting and an ending Point.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo</IRI>
        <Literal xml:lang="es">Tramo definido por un punto de inicio y fin que puede pertenecer a una o más vías</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:isDefinedBy"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo</IRI>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico</IRI>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo</IRI>
        <Literal xml:lang="en">Section of Track</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo</IRI>
        <Literal xml:lang="es">Tramo</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#carga</IRI>
        <Literal xml:lang="en">It is obtained by the equation of intensity and time of occupation with certain correction factors. It is expressed as a percentage: a 100% load implies circulatory collapse, interrupted circulation, while 0% implies empty street. It is similar to the Level of Service of the road that is usually measured with the letters A, B, C, D, E and F: level A, between 0% and 20% load; level F, between 90% and 100% load. The level of service is complex to measure and that is why the load is used.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#carga</IRI>
        <Literal xml:lang="es">Se obtiene mediante ecuación de intensidad y tiempo de ocupación con ciertos factores de corrección. Se expresa en tanto por ciento: una carga del 100% implica colapso circulatorio, circulación interrumpida, mientras que 0% implica calle vacía. Es similar al Nivel de Servicio de la vía que habitualmente se mide con las letras A, B, C, D, E y F: nivel A, entre 0% y 20% de carga; nivel F, entre 90% y 100% de carga. El nivel de servicio es complejo de medir y por eso se usa la carga.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#carga</IRI>
        <Literal xml:lang="es">carga</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#carga</IRI>
        <Literal xml:lang="en">traffic load</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#composicion</IRI>
        <Literal xml:lang="en">It is obtained by the equation of intensity and time of occupation with certain correction factors. It is expressed as a percentage: a 100% load implies circulatory collapse, interrupted circulation, while 0% implies empty street. It is similar to the Level of Service of the road that is usually measured with the letters A, B, C, D, E and F: level A, between 0% and 20% load; level F, between 90% and 100% load. The level of service is complex to measure and that is why the load is used.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#composicion</IRI>
        <Literal xml:lang="es">Se refiere al tipo de vehículos que se suman en la intensidad y a día de hoy sólo se pueden medir a mano mediante muestreo y calcular coeficientes de corrección para las intensidad. Los vehículos se deben referir a vehículos tipo y estiman valores aproximados: turismo=1 ; motocicleta=0,75; Bicicleta=0,5; Autobús=1,5; Camión grande=2.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#composicion</IRI>
        <Literal xml:lang="es">composicion</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#composicion</IRI>
        <Literal xml:lang="en">composition</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#enServicio</IRI>
        <Literal xml:lang="es">Esta propiedad permite conocer si el dispositivo funciona o no.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#enServicio</IRI>
        <Literal xml:lang="en">This property allows describing whether the device is working or not.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#enServicio</IRI>
        <Literal xml:lang="es">En Servicio</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#enServicio</IRI>
        <Literal xml:lang="en">Running device</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#esRecurrente</IRI>
        <Literal xml:lang="es">Esta propiedad permite describir si la incidencia es recurrente o no.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#esRecurrente</IRI>
        <Literal xml:lang="en">This property allows describing whether there is a recurrence in the incidence or not</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#esRecurrente</IRI>
        <Literal xml:lang="es">Incidencia recurrente</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#esRecurrente</IRI>
        <Literal xml:lang="en">Recurrent incidence</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#fechaFinPrevista</IRI>
        <Literal xml:lang="es">La fecha y hora prevista de
	finalización de una incidencia planificada (en formato fecha ISO 8601)</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
