        <Literal xml:lang="en">attached to incidence</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#incidenciaEnTramo</IRI>
        <Literal xml:lang="es">Relación de la Incidencia con el Tramo donde se produce la misma.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#incidenciaEnTramo</IRI>
        <Literal xml:lang="en">Relationship of the Incidence withe the  Section, where it happens.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
