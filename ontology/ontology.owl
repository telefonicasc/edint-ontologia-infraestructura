    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AccessPoint</IRI>
        <Literal xml:lang="es">Es un punto en donde se monitoriza el acceso de vehóculos o personas.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#AccessPoint</IRI>
        <Literal xml:lang="en">It is a point where the access of vehicles or people is monitored.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#AccessPoint</IRI>
        <Literal>Access point</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#AccessPoint</IRI>
        <Literal xml:lang="es">Punto de acceso</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CountingPoint</IRI>
        <Literal xml:lang="es">Es un punto en donde se realiza un conteo de aforo de vehículos o personas.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CountingPoint</IRI>
        <Literal xml:lang="en">It is a point where a count of the number of vehicles or people is carried out.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CountingPoint</IRI>
        <Literal xml:lang="en">Counting point</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CountingPoint</IRI>
        <Literal xml:lang="es">Punto de conteo</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ExternalOrganization</IRI>
        <Literal xml:lang="en">An organization external to the municipal administration that has a role in the management of a municipal facility.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ExternalOrganization</IRI>
        <Literal xml:lang="es">Organización externa a la administración municipal que tiene algún rol en la gestión del equipamiento municipal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ExternalOrganization</IRI>
        <Literal xml:lang="en">External organization</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ExternalOrganization</IRI>
        <Literal xml:lang="es">Organización externa</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Infraction</IRI>
        <Literal xml:lang="es">Incumplimiento o violación de las normas de tránsito o acceso, leyes de circulación u ordenanzas locales por parte de una persona o de un conductor o propietario de un vehículo.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#Infraction</IRI>
        <Literal xml:lang="en">Non-compliance or violation of traffic or access rules, road laws or local ordinances by a person or a driver or owner of a vehicle.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Infraction</IRI>
        <Literal xml:lang="es">Infracción</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#Infraction</IRI>
        <Literal xml:lang="en">Infraction</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#InfrastructureElement</IRI>
        <Literal xml:lang="es">Representa el conjunto de todos los elementos de la infraestructura que generan movilidad y elementos urbanos tales como semáforos, señales viales, pilonas, etc.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#InfrastructureElement</IRI>
        <Literal xml:lang="en">Represents the set of all infrastructure elements that generate mobility and urban elements such as traffic lights, road signs, bollards, etc.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#InfrastructureElement</IRI>
        <Literal xml:lang="es">Elemento de la infraestructura</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#InfrastructureElement</IRI>
        <Literal xml:lang="en">Infrastructure element</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#InfrastructureObservation</IRI>
        <Literal xml:lang="en">Infrastructure observation</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#InfrastructureObservation</IRI>
        <Literal xml:lang="es">Observación en infraestructura</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#InfrastructureObservation</IRI>
        <Literal xml:lang="es">Observación hecha sobre vehiculos o personas en cualquier elemento de la infraestructura. Inclutye observaciones de tráfico y observaciones realizadas en puntos de acceso o puntos de conteo.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#InfrastructureObservation</IRI>
        <Literal xml:lang="en">Observations made on vehicles or people at any element of the infrastructure. Includes traffic observations and observations made at access points or counting points.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#InfrastructureSensor</IRI>
        <Literal xml:lang="es">Sensor de infraestructura</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#InfrastructureSensor</IRI>
        <Literal xml:lang="en">Sensor for making observations of traffic, access or count at any observation point of the infrastructure.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#InfrastructureSensor</IRI>
        <Literal xml:lang="en">Infrastructure sensor</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#InfrastructureSensor</IRI>
        <Literal xml:lang="es">Sensor para realizar observaciones de tráfico, acceso o conteo en cualquier punto de observación de la infraestructura.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ManagementRole</IRI>
        <Literal xml:lang="es">Rol que realiza la administración municipal o alguna de sus dependencias en la gestión del equipamiento. Puede ser el rol de titularidad, mantenimiento, seguridad, entre otros.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#ManagementRole</IRI>
        <Literal xml:lang="en">The role that the municipal administration or one of its departments plays in the management of a municipal facility. This may include ownership, maintenance, security, among others.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ManagementRole</IRI>
        <Literal xml:lang="en">Management role</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#ManagementRole</IRI>
        <Literal xml:lang="es">Rol de gestión</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#MobilityGeneratorFacility</IRI>
        <Literal xml:lang="es">Hace referencia a edificios de servicios (públicos o privados), zonas de ocio, zonas comerciales o cualquier otro elemento  que afecte directamente a la movilidad, actuando como un foco de atracción de vehículos.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#MobilityGeneratorFacility</IRI>
        <Literal xml:lang="en">It refers to service buildings (public or private), leisure areas, commercial areas or any other element that directly affects mobility, acting as a focus of attraction for vehicles.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#MobilityGeneratorFacility</IRI>
        <Literal xml:lang="es">Equipamiento generador de movilidad</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#MobilityGeneratorFacility</IRI>
        <Literal xml:lang="en">Mobility generator facility</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#MunicipalFacility</IRI>
        <Literal xml:lang="es">Equipamientos a los que un ciudadano puede acudir pertenecientes a una administración municipal. Un equipamiento puede ser un aparcamiento, un centro educativo, una estación de bicicleta compartida y cualquier edificio que sea un centro de salud, centro educativo, centro social, comisaría, entre otros.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#MunicipalFacility</IRI>
        <Literal xml:lang="en">Facilities that citizens can access and that belong to a municipal administration. A facility can be a parking lot, an educational center, a bike-sharing station, or any building that serves as a health center, educational center, community center, police station, among others.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#MunicipalFacility</IRI>
        <Literal xml:lang="es">Equipamiento municipal</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#MunicipalFacility</IRI>
        <Literal xml:lang="en">Municipal facility</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#MunicipalService</IRI>
        <Literal xml:lang="es">Administración municipal o cualquiera de sus dependencias que tienen un rol en la gestión de un equipamiento municipal.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#MunicipalService</IRI>
        <Literal xml:lang="en">Municipal administration or any of its departments that have a role in the management of a municipal facility.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#MunicipalService</IRI>
        <Literal xml:lang="en">Municipal service</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#MunicipalService</IRI>
        <Literal xml:lang="es">Servicio municipal</Literal>
    </AnnotationAssertion>
