    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#frecuenciaMedicion</IRI>
        <Literal xml:lang="es">Esta propiedad permite conocer la frecuencia de medición del dispositivo.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>http://vocab.ciudadesabiertas.es/def/transporte/trafico#frecuenciaMedicion</IRI>
