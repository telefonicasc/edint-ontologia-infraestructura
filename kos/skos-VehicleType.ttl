@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix edintinfp: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructurapublica#> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix edintvehicletype: <http://vocab.linkeddata.es/datosabiertos/kos/edint/VehicleType/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:VehicleType a skos:ConceptScheme ; 
    dct:issued "2026-02-19"^^xsd:date ;
    dct:modified "2026-02-19"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Tipo de vehículo"@en ;
    rdfs:label "Type of vehicle"@es ;
    dct:title "Concept scheme grouping types of vehicle that are for groups of public parking spots"@en ;
    dct:title "Esquema de conceptos agrupando tipos de vehículo para grupos de plazas de aparcamiento público"@es .
    

#################################################################
#
#    Concepts
#
#################################################################

edintvehicletype:car a skos:Concept;
  skos:inScheme edintkos:VehicleType;
  skos:prefLabel "Coche"@es ;
  skos:prefLabel "Car"@en .

edintvehicletype:motorcycle a skos:Concept;
  skos:inScheme edintkos:VehicleType;
  skos:prefLabel "Motocicleta"@es ;
  skos:prefLabel "Motorcycle"@en .

edintvehicletype:bycicle a skos:Concept;
  skos:inScheme edintkos:VehicleType;
  skos:prefLabel "Bicicleta"@es ;
  skos:prefLabel "Bycicle"@en .

edintvehicletype:passengervehicle a skos:Concept;
  skos:inScheme edintkos:VehicleType;
  skos:prefLabel "Turismo"@es ;
  skos:prefLabel "Passenger vehicles"@en .

edintvehicletype:van a skos:Concept;
  skos:inScheme edintkos:VehicleType;
  skos:prefLabel "Furgoneta"@es ;
  skos:prefLabel "Van"@en .





