@prefix : <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#> .

<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura> rdf:type owl:Ontology ;
                                                                                           owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura/0.1.0> ;
                                                                                           <http://purl.org/dc/terms/created> "2026-01-30" ;
                                                                                           <http://purl.org/dc/terms/creator> "Daniel Doña" ,
                                                                                                                              "Edna Ruckhaus" ,
                                                                                                                              "Lucía Sánchez" ,
                                                                                                                              "Oscar Corcho" ,
                                                                                                                              "Socorro Bernardos" ;
                                                                                           <http://purl.org/dc/terms/description> "La ontología de infraestructura describe todos los conceptos relacionados con las instalaciones públicas y privadas de un municipio.  Estas incluyen aparcamientos dentro y fuera de la vía pública, bibliotecas, centros de salud, centros sociales, juzgados, comisarías, centros educativos, entre otros."@es ,
                                                                                                                                  "The infrastructure ontology describes all concepts related to a municipality's public and private facilities. These include on-street and off-street parking, libraries, health centers, community centers, courthouses, police stations, educational centers, among others."@en ;
                                                                                           <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                                                           <http://purl.org/dc/terms/title> "Ontología de Infraestructura"@es ,
                                                                                                                            "The Infrastructure Ontology"@en ;
                                                                                           <http://purl.org/vocab/vann/preferredNamespacePrefix> "edintinf" ;
                                                                                           <http://purl.org/vocab/vann/preferredNamespaceUri> : ;
                                                                                           owl:versionInfo "0.2.0" .

