xsd:gYearMonth rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://schema.org/address
<http://schema.org/address> rdf:type owl:ObjectProperty ;
                            rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal> ;
                            rdfs:comment "Dirección física de la entidad,"@es ;
                            rdfs:isDefinedBy <http://schema.org> ;
                            rdfs:label "address"@en ,
                                       "dirección"@en .


###  http://schema.org/manufacturer
<http://schema.org/manufacturer> rdf:type owl:ObjectProperty ;
                                 rdfs:domain [ rdf:type owl:Class ;
                                               owl:unionOf ( <http://vocab.ciudadesabiertas.es/def/transporte/trafico#DispositivoMedicionTrafico>
                                                             :AccessSensor
                                                             :CountingSensor
                                                           )
                                             ] ;
                                 rdfs:range <https://schema.org/Organization> ;
                                 rdfs:comment "El fabricante del producto."@es ,
                                              "The manufacturer of the product."@en ;
                                 rdfs:isDefinedBy <http://schema.org/> ;
                                 rdfs:label "fabricante"@es ,
                                            "manufacturer"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#finTramo
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#finTramo> rdf:type owl:ObjectProperty ,
                                                                            owl:FunctionalProperty ;
                                                                   rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> ;
                                                                   rdfs:range <http://www.opengis.net/ont/sf#Point> ;
                                                                   rdfs:comment "Relación del tramo con el lugar donde finaliza el tramo."@es ,
                                                                                "Relationship of the section with the point where it ends."@en ;
                                                                   rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                   rdfs:label "Fin del Tramo"@es ,
                                                                              "Section end"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#incidenciaEnTramo
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#incidenciaEnTramo> rdf:type owl:ObjectProperty ,
                                                                                     owl:FunctionalProperty ;
                                                                            rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia> ;
                                                                            rdfs:range <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> ;
                                                                            rdfs:comment "Relación de la Incidencia con el Tramo donde se produce la misma."@es ,
                                                                                         "Relationship of the Incidence withe the  Section, where it happens."@en ;
                                                                            rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                            rdfs:label "Incidence in Section"@en ,
                                                                                       "Incidencia en tramo"@es .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo> rdf:type owl:ObjectProperty ,
                                                                               owl:FunctionalProperty ;
                                                                      rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> ;
                                                                      rdfs:range <http://www.opengis.net/ont/sf#Point> ;
                                                                      rdfs:comment "Relación del tramo con el lugar donde se inicia el tramo."@es ,
                                                                                   "Relationship of the section with the point where it starts."@en ;
                                                                      rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                      rdfs:label "Inicio del Tramo"@es ,
                                                                                 "Section start"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#monitorea
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#monitorea> rdf:type owl:ObjectProperty ,
                                                                             owl:FunctionalProperty ;
                                                                    rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico> ;
                                                                    rdfs:range <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> ;
                                                                    rdfs:comment "Relación del Equipo de Tráfico con el Tramo que monitorea"@es ,
                                                                                 "Relationship between Traffic Equipment and the Section it monitors"@en ;
                                                                    rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                    rdfs:label "Monitorea"@es ,
                                                                               "Monitors"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#tipoEquipoTrafico
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#tipoEquipoTrafico> rdf:type owl:ObjectProperty ,
                                                                                     owl:FunctionalProperty ;
                                                                            rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico> ;
                                                                            rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                                                                                owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/sector-publico/transporte/tipo-equipo-trafico>
                                                                                                              ]
                                                                                                            ) ;
                                                                                         rdf:type owl:Class
                                                                                       ] ;
                                                                            rdfs:comment "Tipo de equipo de tráfico, equipos de control y dispositivos de medición"@es ,
                                                                                         "Type of traffic equipment, monitor equipment or meassuring devices"@en ;
                                                                            rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                            rdfs:label "Tipo de Equipo de Tráfico"@es ,
                                                                                       "Type of Traffic Equipment"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#tipoIncidencia
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#tipoIncidencia> rdf:type owl:ObjectProperty ,
                                                                                  owl:FunctionalProperty ;
                                                                         rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia> ;
                                                                         rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                                                                           [ rdf:type owl:Restriction ;
                                                                                                             owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                                                                             owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/sector-publico/transporte/tipo-incidencia>
                                                                                                           ]
                                                                                                         ) ;
                                                                                      rdf:type owl:Class
                                                                                    ] ;
                                                                         rdfs:comment "Tipo de incidencia, pueden ser planificadas o no planificadas."@es ,
                                                                                      "Type of incidence, planned or unplannedt"@en ;
                                                                         rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                         rdfs:label "Tipo de Incidencia"@es ,
                                                                                    "Type of Incidence"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio> ;
                                                                                   rdfs:comment "Municipio al que pertenece un fenómeno geográfico o una entidad administrativa"@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                   rdfs:label "pertenece a municipio"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contienePortal
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contienePortal> rdf:type owl:ObjectProperty ;
                                                                                                   rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal> ;
                                                                                                   rdfs:comment "Portal que un fenómeno geográfico contiene (por ejemplo, una vía o un tramo de vía, aunque también puede ser un barrio, distrito, ciudad, etc.)"@es ;
                                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> ;
                                                                                                   rdfs:label "contiene portal"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contieneVia
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contieneVia> rdf:type owl:ObjectProperty ;
                                                                                                rdfs:subPropertyOf <http://www.opengis.net/ont/geosparql#sfContains> ;
                                                                                                rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via> ;
                                                                                                <http://purl.org/dc/terms/issued> "2014-03-28" ;
                                                                                                rdfs:comment "Vía que un fenómeno geográfico contiene (por ejemplo, un barrio, distrito, ciudad, etc.)"@es ;
                                                                                                rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> ;
                                                                                                rdfs:label "contiene vía"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#belongsTo
:belongsTo rdf:type owl:ObjectProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( :InfrastructureElement
                                       :ObservationPoint
                                     )
                       ] ;
           rdfs:range [ rdf:type owl:Class ;
                        owl:unionOf ( <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia>
                                      <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio>
                                      <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Ciudad>
                                      <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito>
                                      <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio>
                                      <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Provincia>
                                    )
                      ] ;
           rdfs:comment "Relación entre un elemento de infraestructura y la división administrativa a la cual pertenece, incluido un Barrio."@es ,
                        "Relationship between an infrastructure element and the administrative division to which it belongs, including a neighborhood."@en ;
           rdfs:label "belongs to"@en ,
                      "pertenece a"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#containsFacility
:containsFacility rdf:type owl:ObjectProperty ;
                  rdfs:domain :Facility ;
                  rdfs:range :Facility ;
                  rdfs:comment "A  facility may contain other facilities. For example, a cultural center may contain exhibition halls, auditoriums, etc."@en ,
                               "Un equipamiento  puede contener otros equipamientos. Por ejemplo, un centro cultural puede contener salas de exposiciòn, auditorios, etc."@es ;
                  rdfs:label "contains facility"@en ,
                             "contiene equipamiento"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasInfrastructureType
:hasInfrastructureType rdf:type owl:ObjectProperty ;
                       rdfs:domain :InfrastructureElement ;
                       rdfs:comment "Relación entre un elemento de infraestructura y un concepto de la taxonomía de tipos de elemento de infraestructura."@es ,
                                    "Relationship between an infrastructure element and a concept from the taxonomy of infrastructure element types."@en ;
                       rdfs:label "has infrastructure element type"@en ,
                                  "tiene tipo de elemento de infraestructura"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasObservationPoint
:hasObservationPoint rdf:type owl:ObjectProperty ;
                     rdfs:domain :InfrastructureElement ;
                     rdfs:range :ObservationPoint ;
                     rdfs:comment "Relación entre un elemento de la infraestructura y un punto de observación."@es ,
                                  "Relationship between an infrastructure element and an observation point."@en ;
                     rdfs:label "has observation point"@en ,
                                "tiene punto de observación"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasRegisteredOwner
:hasRegisteredOwner rdf:type owl:ObjectProperty ;
                    rdfs:domain :InfrastructureElement ;
                    rdfs:range :Organization ;
                    rdfs:comment "Relación entre un elemento de infraestructura y su titular, generalmente una organización"@en ,
                                 "Relationship between an infrastructure element and its owner, which is usually an organization."@en ;
                    rdfs:label "has registered owner"@en ,
                               "tiene titular registrado"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasRoleType
:hasRoleType rdf:type owl:ObjectProperty ;
             rdfs:domain :ManagementRole ;
             rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                 owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/RoleType>
                                               ]
                                             ) ;
                          rdf:type owl:Class
                        ] ;
             rdfs:comment "Relación entre el Rol de gestión y la taxonomía de roles de gestión."@es ,
                          "Relationship between the management role and the taxonomy of management roles."@en ;
             rdfs:label "has role type"@en ,
                        "tiene tipo de rol"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasViolationType
:hasViolationType rdf:type owl:ObjectProperty ;
                  rdfs:domain :Violation ;
                  rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                      owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/ViolationType>
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
                  rdfs:comment "Relaciona a una Infracción con un concepto de la taxonomía de tipos de infracción."@es ,
                               "Relate an Infraction to a concept from the taxonomy of infraction types."@en ;
                  rdfs:label "has violation type"@en ,
                             "tiene tipo de infracción"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#includesVehicle
:includesVehicle rdf:type owl:ObjectProperty ;
                 rdfs:domain :AccessObservation ;
                 rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle> ;
                 rdfs:comment "Property that connects an observation to the observed vehicle."@en ,
                              "Propiedad que relaciona una observación con el vehículo observado"@es ;
                 rdfs:label "includes vehicle"@en ,
                            "incluye vehículo"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#linkedTo
:linkedTo rdf:type owl:ObjectProperty ;
          rdfs:domain :Violation ;
          rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle> ;
          rdfs:comment "Relación entre una infracción y el vehículo que cometió la infracción."@es ,
                       "Relationship between an infraction and the vehicle that committed the infraction."@en ;
          rdfs:label "asociado a"@es ,
                     "linked to"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#madeOnInfrastructure
:madeOnInfrastructure rdf:type owl:ObjectProperty ;
                      rdfs:domain :ManagementRole ;
                      rdfs:range :InfrastructureElement ;
                      rdfs:comment "Relación entre el rol de gestion que ejerce una organización  y el elemento de infraestructura sobre el cual se realiza la gestión."@es ,
                                   "Relationship between the management role exercised by an organization and the infrastructure element on which the management is carried out."@en ;
                      rdfs:label "made on an infrastructure element"@en ,
                                 "realizado sobre elemento de infraestructura"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#offersRegularActivity
:offersRegularActivity rdf:type owl:ObjectProperty ;
                       rdfs:domain :Facility ;
                       rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                           owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/RegularActivity>
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
                       rdfs:comment "Actividad que se lleva a cabo regularmente en el equipamiento."@es ,
                                    "Activity that is carried out regularly in a facility."@en ;
                       rdfs:label "offers regular activity"@en ,
                                  "ofrece actividad regular"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#provesViolation
:provesViolation rdf:type owl:ObjectProperty ;
                 rdfs:domain :AccessObservation ;
                 rdfs:range :Violation ;
                 rdfs:comment "Relación entre la observación urbana y la infracción que está soportando."@es ,
                              "Relationship between an observation and the infraction it is proving."@en ;
                 rdfs:label "demuestra infracción"@es ,
                            "proofs violation"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#providesPublicService
:providesPublicService rdf:type owl:ObjectProperty ;
                       rdfs:domain :Facility ;
                       rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                           owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/PublicService>
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
                       rdfs:comment "Public service provided by a facility, for example internet via wifi."@en ,
                                    "Servicio público prestado por un equipamiento, por ejemplo internet a través de una wifi."@es ;
                       rdfs:label "presta servicio público"@es ,
                                  "provides public service"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#rolePlayedBy
:rolePlayedBy rdf:type owl:ObjectProperty ;
              rdfs:domain :ManagementRole ;
              rdfs:range :Organization ;
              rdfs:comment "Relación entre el rol de gestión sobre un equipamiento municipal y la organización que lo ejerce."@es ,
                           "Relationship between the management role over a municipal facility and the organization that exercises it."@en ;
              rdfs:label "rol ejercido por"@es ,
                         "role played by"@en .


###  http://www.geonames.org/ontology#featureClass
<http://www.geonames.org/ontology#featureClass> rdf:type owl:ObjectProperty .


###  http://www.geonames.org/ontology#featureCode
<http://www.geonames.org/ontology#featureCode> rdf:type owl:ObjectProperty .


###  http://www.opengis.net/ont/geosparql#hasGeometry
<http://www.opengis.net/ont/geosparql#hasGeometry> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <http://www.opengis.net/ont/geosparql#Feature> ;
                                                   rdfs:range <http://www.opengis.net/ont/geosparql#Geometry> ;
                                                   rdfs:comment "Una representación espacial de un \"feature\" determinado."@es ;
                                                   rdfs:isDefinedBy <http://www.opengis.net/spec/geosparql/1.0> ;
                                                   rdfs:label "has geometry"@en ,
                                                              "tiene geometría"@es .


###  http://www.opengis.net/ont/geosparql#sfContains
<http://www.opengis.net/ont/geosparql#sfContains> rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:ObjectProperty ;
                                               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core#> .


###  http://www.w3.org/2006/time#hasBeginning
<http://www.w3.org/2006/time#hasBeginning> rdf:type owl:ObjectProperty ;
                                           rdfs:subPropertyOf <http://www.w3.org/2006/time#hasTime> ;
                                           rdfs:comment "Beginning of a temporal entity"@en ,
                                                        "Comienzo de una entidad temporal."@es ;
                                           rdfs:label "has beginning"@en ,
                                                      "tiene principio"@es ;
                                           <http://www.w3.org/2004/02/skos/core#definition> "Beginning of a temporal entity."@en ,
                                                                                            "Comienzo de una entidad temporal."@es .


###  http://www.w3.org/2006/time#hasEnd
<http://www.w3.org/2006/time#hasEnd> rdf:type owl:ObjectProperty ;
                                     rdfs:subPropertyOf <http://www.w3.org/2006/time#hasTime> ;
                                     rdfs:comment "End of a temporal entity."@en ,
                                                  "Final de una entidad temporal."@es ;
                                     rdfs:label "has end"@en ,
                                                "tiene fin"@es ;
                                     <http://www.w3.org/2004/02/skos/core#definition> "End of a temporal entity."@en ,
                                                                                      "Final de una entidad temporal."@es .


###  http://www.w3.org/2006/time#hasTime
<http://www.w3.org/2006/time#hasTime> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/sosa/hasFeatureOfInterest
<http://www.w3.org/ns/sosa/hasFeatureOfInterest> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <http://www.w3.org/ns/sosa/Observation> ;
                                                 rdfs:range <http://www.w3.org/ns/sosa/FeatureOfInterest> ;
                                                 rdfs:comment "Una relación entre una Observación y la entidad cuya calidad fue observada, o entre una Actuación y la entidad cuya propiedad fue modificada, o entre un acto de muestreo y la entidad que fue muestreada."@es ;
                                                 rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ;
                                                 rdfs:label "tiene entidad de interés"@es ,
                                                            "has feature of interest" .


###  http://www.w3.org/ns/sosa/madeBySensor
<http://www.w3.org/ns/sosa/madeBySensor> rdf:type owl:ObjectProperty ;
                                         rdfs:domain <http://www.w3.org/ns/sosa/Observation> ;
                                         rdfs:range <http://www.w3.org/ns/sosa/Sensor> ;
                                         rdfs:comment "Relación entre una observación y el sensor que realiza la observación."@es ;
                                         rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ;
                                         rdfs:label "made by sensor or observer"@en ,
                                                    "realizado por sensor u observador"@es .


###  http://www.w3.org/ns/sosa/observedProperty
<http://www.w3.org/ns/sosa/observedProperty> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://www.w3.org/ns/sosa/wasObservedBy> ;
                                             rdfs:domain <http://www.w3.org/ns/sosa/Observation> ;
                                             rdfs:range <http://www.w3.org/ns/sosa/ObservableProperty> ;
                                             <http://schema.org/domainIncludes> <http://www.w3.org/ns/sosa/Observation> ,
                                                                                <http://www.w3.org/ns/sosa/ObservationCollection> ;
                                             <http://schema.org/rangeIncludes> <http://www.w3.org/ns/sosa/ObservableProperty> ,
                                                                               <http://www.w3.org/ns/sosa/Property> ;
                                             rdfs:comment "Relation linking an Observation to the property that was observed. The ObservableProperty should be a property of the FeatureOfInterest (linked by hasFeatureOfInterest) of this Observation."@en ;
                                             rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ,
                                                              <http://www.w3.org/ns/sosa/obs/> ;
                                             rdfs:label "observed property"@en ;
                                             <http://www.w3.org/2004/02/skos/core#definition> """
  relation from an Observation or ObservationCollection to the property that was observed
  """@en ,
                                                                                              "Relation linking an Observation to the property that was observed. The ObservableProperty should be a property of the FeatureOfInterest (linked by hasFeatureOfInterest) of this Observation."@en ;
                                             <http://www.w3.org/2004/02/skos/core#note> """
  'observed property' covers the concepts referred to in [VIM] as 'measurand' (quantitative values) and 'examinand' (categorical and nominal values — [VIM4]), as well as complex and structured properties whose values may be represented as lists, vectors, arrays, rasters, geometries, etc. More specific terms are used in other contexts for related concepts, such as 'analyte' (chemistry) and 'determinand' (water quality).
  """@en .


###  http://www.w3.org/ns/sosa/observes
<http://www.w3.org/ns/sosa/observes> rdf:type owl:ObjectProperty ;
                                     rdfs:domain <http://www.w3.org/ns/sosa/Sensor> ;
                                     rdfs:range <http://www.w3.org/ns/sosa/ObservableProperty> ;
                                     rdfs:comment "Relación entre un sensor y una propiedad observable que es capaz de detectar."@es ;
                                     rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ;
                                     rdfs:label "observa"@es ,
                                                "observes"@en .


###  http://www.w3.org/ns/sosa/phenomenonTime
<http://www.w3.org/ns/sosa/phenomenonTime> rdf:type owl:ObjectProperty ;
                                           <http://schema.org/domainIncludes> <http://www.w3.org/ns/sosa/Actuation> ,
                                                                              <http://www.w3.org/ns/sosa/Observation> ,
                                                                              <http://www.w3.org/ns/sosa/ObservationCollection> ,
                                                                              <http://www.w3.org/ns/sosa/Sampling> ;
                                           rdfs:comment "El momento en que el resultado de una observación, actuación o muestreo se aplica a la entidad de interés. No necesariamente coincide con el momento del resultado. Puede ser un intervalo, un instante o alguna otra entidad temporal compuesta."@es ,
                                                        "The time that the Result of an Observation, Actuation or Sampling applies to the FeatureOfInterest. Not necessarily the same as the resultTime. May be an Interval or an Instant, or some other compound TemporalEntity."@en ;
                                           rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ,
                                                            <http://www.w3.org/ns/sosa/common/> ;
                                           rdfs:label "momento del fenómeno"@es ,
                                                      "phenomenon time"@en ;
                                           <http://www.w3.org/2004/02/skos/core#definition> "The time that the Result of an Observation, Actuation or Sampling applies to the FeatureOfInterest. Not necessarily the same as the resultTime. May be an Interval or an Instant, or some other compound TemporalEntity."@en .


###  http://www.w3.org/ns/sosa/wasObservedBy
<http://www.w3.org/ns/sosa/wasObservedBy> rdf:type owl:ObjectProperty ;
                                          rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:DatatypeProperty ;
                                      rdfs:range rdfs:Literal ;
                                      rdfs:comment "An unambiguous reference to the resource within a given context."@en ,
                                                   "Una referencia no ambigüa al recurso dentro de un contexto determinado."@es ;
                                      rdfs:isDefinedBy <http://purl.org/dc/terms/> ;
                                      rdfs:label "identificador"@es ,
                                                 "identifier"@en .


###  http://schema.org/endDate
<http://schema.org/endDate> rdf:type owl:DatatypeProperty ;
                            rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia> ;
                            rdfs:range xsd:dateTime ;
                            rdfs:comment "La fecha y hora de finalización del elemento (en formato de fecha ISO 8601)."@es ,
                                         "The end date and time of the item (in ISO 8601 date format)."@en ,
                                         "end date"@en ;
                            rdfs:isDefinedBy <http://schema.org> ;
                            rdfs:label "fecha de finalización"@es .


###  http://schema.org/openingHours
<http://schema.org/openingHours> rdf:type owl:DatatypeProperty ;
                                 rdfs:domain :Facility ;
                                 rdfs:range xsd:string ;
                                 rdfs:comment "Horario general de apertura de un negocio. El horario se puede especificar como un rango semanal, comenzando por días y luego por horas al día. Se pueden indicar varios días separados por comas (\",\"). Los rangos de días u horas se especifican con un guion (-)."@es ,
                                              "The general opening hours for a business. Opening hours can be specified as a weekly time range, starting with days, then times per day. Multiple days can be listed with commas ',' separating each day. Day or time ranges are specified using a hyphen '-'."@en ;
                                 rdfs:isDefinedBy <http://schema.org> ;
                                 rdfs:label "horario de apertura"@es ,
                                            "opening hours"@en .


###  http://schema.org/startDate
<http://schema.org/startDate> rdf:type owl:DatatypeProperty ;
                              rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia> ;
                              rdfs:range xsd:dateTime ;
                              rdfs:comment "La fecha y hora de inicio del elemento (en formato de fecha ISO 8601)."@es ,
                                           "The start date and time of the item (in ISO 8601 date format)."@en ;
                              rdfs:isDefinedBy <http://schema.org> ;
                              rdfs:label "fecha de inicio"@es ,
                                         "start date"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#enServicio
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#enServicio> rdf:type owl:DatatypeProperty ;
                                                                     rdfs:subPropertyOf owl:topDataProperty ;
                                                                     rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#DispositivoMedicionTrafico> ;
                                                                     rdfs:range xsd:boolean ;
                                                                     rdfs:comment "Esta propiedad permite conocer si el dispositivo funciona o no."@es ,
                                                                                  "This property allows describing whether the device is working or not."@en ;
                                                                     rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                     rdfs:label "En Servicio"@es ,
                                                                                "Running device"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#esRecurrente
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#esRecurrente> rdf:type owl:DatatypeProperty ;
                                                                       rdfs:subPropertyOf owl:topDataProperty ;
                                                                       rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaPlanificada> ;
                                                                       rdfs:range xsd:boolean ;
                                                                       rdfs:comment "Esta propiedad permite describir si la incidencia es recurrente o no."@es ,
                                                                                    "This property allows describing whether there is a recurrence in the incidence or not"@en ;
                                                                       rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico#> ;
                                                                       rdfs:label "Incidencia recurrente"@es ,
                                                                                  "Recurrent incidence"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#fechaFinPrevista
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#fechaFinPrevista> rdf:type owl:DatatypeProperty ;
                                                                           rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaPlanificada> ;
                                                                           rdfs:range xsd:dateTime ;
                                                                           rdfs:comment """La fecha y hora prevista de
	finalización de una incidencia planificada (en formato fecha ISO 8601)"""@es ,
                                                                                        "The end date and time of a planned incidence (in ISO 8601 date format)."@en ;
                                                                           rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico/> ;
                                                                           rdfs:label "(expected) end date"@en ,
                                                                                      "fecha de fin (prevista)"@es .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#frecuenciaMedicion
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#frecuenciaMedicion> rdf:type owl:DatatypeProperty ;
                                                                             rdfs:subPropertyOf owl:topDataProperty ;
                                                                             rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#DispositivoMedicionTrafico> ;
                                                                             rdfs:range xsd:string ;
                                                                             rdfs:comment "Esta propiedad permite conocer la frecuencia de medición del dispositivo."@es ,
                                                                                          "This property allows to know the measurement frequency of the device."@en ;
                                                                             rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico#> ;
                                                                             rdfs:label "Frecuencia Medición"@es ,
                                                                                        "Measurement Frequency"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#incidenciaAdjunto
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#incidenciaAdjunto> rdf:type owl:DatatypeProperty ;
                                                                            rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia> ;
                                                                            rdfs:range xsd:anyURI ;
                                                                            rdfs:comment "A document where more information about the incidence can be found."@en ,
                                                                                         "Un documento donde se puede consultar la información sobre la incidencia."@es ;
                                                                            rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                            rdfs:label "adjunto a la incidencia"@es ,
                                                                                       "attached to incidence"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#numSentidos
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#numSentidos> rdf:type owl:DatatypeProperty ;
                                                                      rdfs:domain [ rdf:type owl:Class ;
                                                                                    owl:unionOf ( <http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico>
                                                                                                  <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia>
                                                                                                )
                                                                                  ] ;
                                                                      rdfs:range xsd:integer ;
                                                                      rdfs:comment "Number of directions of traffic"@en ,
                                                                                   "Número de sentidos de circulación"@es ;
                                                                      rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                      rdfs:label "Sentidos de circulación"@es ,
                                                                                 "Street directions"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#recurrencia
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#recurrencia> rdf:type owl:DatatypeProperty ;
                                                                      rdfs:subPropertyOf owl:topDataProperty ;
                                                                      rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaPlanificada> ;
                                                                      rdfs:range xsd:string ;
                                                                      rdfs:comment "Esta propiedad permite describir la recurrencia."@es ,
                                                                                   "This property allows describing the recurrence"@en ;
                                                                      rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico#> ;
                                                                      rdfs:label "Recurrence"@en ,
                                                                                 "Recurrencia"@es .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#unidadMedida
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#unidadMedida> rdf:type owl:DatatypeProperty ;
                                                                       rdfs:subPropertyOf owl:topDataProperty ;
                                                                       rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico> ;
                                                                       rdfs:range xsd:string ;
                                                                       rdfs:comment "En el caso del nivel del servicio, las medidas posibles son: verde o fluido; amarillo o lento; naranja o denso; rojo o congestión; negro o circulación interrumpida; gris o sin datos."@es ,
                                                                                    "Esta propiedad permite describir la unidad de medida de la medición del Dispositivo de Medición de Tráfico."@es ,
                                                                                    "In the case of the Service level (nivel), the possible measures are: green or fluid; yellow or slow; orange or dense; red or congestion; black or interrupted circulation; grey or no data."@en ,
                                                                                    "This property allows describing the unit of measurement of the Trafic Monitoring Device"@en ;
                                                                       rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico#> ;
                                                                       rdfs:label "Unidad de Medida"@es ,
                                                                                  "Unit of Measurement"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#urbano
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#urbano> rdf:type owl:DatatypeProperty ;
                                                                 rdfs:subPropertyOf owl:topDataProperty ;
                                                                 rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico> ;
                                                                 rdfs:range xsd:boolean ;
                                                                 rdfs:comment "Esta propiedad permite describir si el dispositivo es urbano o no."@es ,
                                                                              "This property allows knowing whether the device is urban or not"@en ;
                                                                 rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico#> ;
                                                                 rdfs:label "Urban"@en ,
                                                                            "Urbano"@es .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#validada
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#validada> rdf:type owl:DatatypeProperty ;
                                                                   rdfs:subPropertyOf owl:topDataProperty ;
                                                                   rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#ObservacionTrafico> ;
                                                                   rdfs:range xsd:boolean ;
                                                                   rdfs:comment "Esta propiedad permite conocer si se ha producido una validación de la observación o no"@es ,
                                                                                "This property states whether the observation is validated or not."@en ;
                                                                   rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico#> ;
                                                                   rdfs:label "Validada"@es ,
                                                                              "Validated Observation"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#complaintCancelled
:complaintCancelled rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Violation ;
                    rdfs:range xsd:boolean ;
                    rdfs:comment "Propiedad que indica si la denuncia (de una infracción) ha sido anulada o no"@es ;
                    rdfs:label "cancelled complaint"@en ,
                               "denuncia anulada"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#installationDate
:installationDate rdf:type owl:DatatypeProperty ;
                  rdfs:domain :UrbanElement ;
                  rdfs:range xsd:dateTime ;
                  rdfs:comment "Date when an entity, especially a device, was installed."@en ,
                               "Fecha en la que se instaló una entidad, especialmente un dispositivo"@es ;
                  rdfs:label "fecha de instalación"@es ,
                             "installation date"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#isPublic
:isPublic rdf:type owl:DatatypeProperty ;
          rdfs:domain <https://schema.org/Organization> ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Property that points out whether an entity, especially an organization, is public or not."@en ,
                       "Propiedad que indica si una entidad, especialmente una Organización, es pública"@es ;
          rdfs:label "es público"@es ,
                     "is public"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#maintenanceDate
:maintenanceDate rdf:type owl:DatatypeProperty ;
                 rdfs:domain :UrbanElement ;
                 rdfs:range xsd:dateTime ;
                 rdfs:comment "Date when an entity was last maintained, especially an urban element."@en ,
                              "Fecha en la que se hizo mantenimiento de una entidad por última vez, especialmente un elemento urbano."@es ;
                 rdfs:label "fecha de mantenimiento"@es ,
                            "maintenance date"@en .


###  http://www.w3.org/2006/time#inXSDgYearMonth
<http://www.w3.org/2006/time#inXSDgYearMonth> rdf:type owl:DatatypeProperty ;
                                              rdfs:range xsd:gYearMonth ;
                                              rdfs:comment "Posición de un instante, expresado utilizando xsd:gYearMonth."@es ,
                                                           "Position of an instant, expressed using xsd:gYearMonth"@en ;
                                              rdfs:isDefinedBy <http://www.w3.org/2006/time#> ;
                                              rdfs:label "en año-mes gregoriano XSD"@es ,
                                                         "in XSD g-YearMonth"@en ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "Posición de un instante, expresado utilizando xsd:gYearMonth."@es ,
                                                                                               "Position of an instant, expressed using xsd:gYearMonth"@en .


###  http://www.w3.org/ns/sosa/hasSimpleResult
<http://www.w3.org/ns/sosa/hasSimpleResult> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://www.w3.org/ns/sosa/Observation> ;
                                            <http://schema.org/domainIncludes> <http://www.w3.org/ns/sosa/Actuation> ,
                                                                               <http://www.w3.org/ns/sosa/Observation> ,
                                                                               <http://www.w3.org/ns/sosa/ObservationCollection> ,
                                                                               <http://www.w3.org/ns/sosa/Sampling> ;
                                            rdfs:comment "The simple value of an Observation or Actuation or act of Sampling."@en ;
                                            rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ,
                                                             <http://www.w3.org/ns/sosa/common/> ;
                                            rdfs:label "has simple result"@en ;
                                            <http://www.w3.org/2004/02/skos/core#definition> "The simple value of an Observation or Actuation or act of Sampling."@en ;
                                            <http://www.w3.org/2004/02/skos/core#example> "For instance, the values 23 or true."@en .


###  http://www.w3.org/ns/sosa/resultTime
<http://www.w3.org/ns/sosa/resultTime> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <http://www.w3.org/ns/sosa/Observation> ;
                                       rdfs:range xsd:dateTime ;
                                       <http://schema.org/domainIncludes> <http://www.w3.org/ns/sosa/Actuation> ,
                                                                          <http://www.w3.org/ns/sosa/Observation> ,
                                                                          <http://www.w3.org/ns/sosa/ObservationCollection> ,
                                                                          <http://www.w3.org/ns/sosa/Sampling> ;
                                       rdfs:comment "The result time is the instant of time when the Observation, Actuation or Sampling activity was completed."@en ;
                                       rdfs:isDefinedBy <http://www.w3.org/ns/sosa/> ,
                                                        <http://www.w3.org/ns/sosa/common/> ;
                                       rdfs:label "result time"@en ;
                                       <http://www.w3.org/2004/02/skos/core#definition> "The result time is the instant of time when the Observation, Actuation or Sampling activity was completed."@en .


###  https://datos.ign.es/def/geo_core#xETRS89
<https://datos.ign.es/def/geo_core#xETRS89> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://www.opengis.net/ont/sf#Point> ;
                                            rdfs:range xsd:float ;
                                            <http://purl.org/dc/elements/1.1/source> "Catálogo de Objetos Geográficos BTN100."@es ;
                                            rdfs:comment "Coordenada X en metros (ETRS89)"@es ,
                                                         "X-Coordinate in meters (ETRS89)"@en ;
                                            rdfs:isDefinedBy <https://datos.ign.es/def/geo_core#> ;
                                            rdfs:label "xETRS89" .


###  https://datos.ign.es/def/geo_core#yETRS89
<https://datos.ign.es/def/geo_core#yETRS89> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://www.opengis.net/ont/sf#Point> ;
                                            rdfs:range xsd:float ;
                                            <http://purl.org/dc/elements/1.1/source> "Catálogo de Objetos Geográficos BTN100."@es ;
                                            rdfs:comment "Coordenada Y en metros (ETRS89)"@es ,
                                                         "Y-Coordinate in meters (ETRS89)"@en ;
                                            rdfs:isDefinedBy <https://datos.ign.es/def/geo_core#> ;
                                            rdfs:label "yETRS89" .


#################################################################
#    Classes
#################################################################

###  http://vocab.ciudadesabiertas.es/def/transporte/bicicleta-publica#EstacionBicicleta
<http://vocab.ciudadesabiertas.es/def/transporte/bicicleta-publica#EstacionBicicleta> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf :Facility ;
                                                                                      rdfs:comment "Lugar donde se puede tanto dejar como recoger las bicicletas. Está compuesto de anclajes"@es ;
                                                                                      rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/bicicleta-publica> ;
                                                                                      rdfs:label "Estación de bicicletas"@es .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#DispositivoMedicionTrafico
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#DispositivoMedicionTrafico> rdf:type owl:Class ;
                                                                                     rdfs:subClassOf <http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico> ,
                                                                                                     <http://www.w3.org/ns/sosa/Sensor> ;
                                                                                     rdfs:comment "Dispositivo de Medición de Tráfico, tipo de equipo de tráfico que realiza mediciones."@es ,
                                                                                                  "Traffic Measuring Device, type of Traffic Device which performs measurements."@en ;
                                                                                     rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                                     rdfs:label "Dispositivo de medición de tráfico"@es ,
                                                                                                "Traffic Measuring Device"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico> rdf:type owl:Class ;
                                                                        rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                        owl:disjointWith <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia> ,
                                                                                         <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> ;
                                                                        rdfs:comment "A traffic equipment monitors the traffic of a city"@en ,
                                                                                     "Un Equipo de Tráfico es uno de los equipos que se encargan de controlar o monitorizar el tráfico de la ciudad."@es ;
                                                                        rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                        rdfs:label "Equipo de tráfico"@es ,
                                                                                   "Traffic equipment"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                     owl:disjointWith <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> ;
                                                                     rdfs:comment "Incidence in the traffic system of a city"@en ,
                                                                                  "Incidencia que ocurre en el sistema de tráfico de una ciudad"@es ;
                                                                     rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                     rdfs:label "Incidence"@en ,
                                                                                "Incidencia"@es .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaNoPlanificada
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaNoPlanificada> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia> ;
                                                                                  rdfs:comment "Incidencia no planificada del tráfico de una ciudad"@es ,
                                                                                               "Unplanned traffic incidence"@en ;
                                                                                  rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                                  rdfs:label "Incidencia no planificada"@es ,
                                                                                             "Unplanned incidence"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaPlanificada
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaPlanificada> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia> ;
                                                                                rdfs:comment "Incidencia planificada, puede ser recurrente o no"@es ,
                                                                                             "Planned traffic incidence"@en ;
                                                                                rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                                rdfs:label "Incidencia planificada"@es ,
                                                                                           "Planned incidence"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#ObservacionTrafico
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#ObservacionTrafico> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <http://www.w3.org/ns/sosa/Observation> ;
                                                                             rdfs:comment "Observación realizada por un Dispositivo de Medición de Tráfico"@es ,
                                                                                          "Observation by a Traffic Measuring Device"@en ;
                                                                             rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                             rdfs:label "Observación del tráfico"@es ,
                                                                                        "Traffic monitoring"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.w3.org/ns/sosa/ObservableProperty> ;
                                                                                   rdfs:comment "Property of the Meassurement of Traffic: composition, load, occupation, intensity, level or speed."@en ,
                                                                                                "Propiedad de la Medición de Tráfico: composición, carga, ocupación, intensidad, nivel o velocidad."@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                                   rdfs:label "Propiedad Medición Tráfico"@es ,
                                                                                              "Traffic meassuring property"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> rdf:type owl:Class ;
                                                                rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                rdfs:comment "Section/s of a Track defined by a starting and an ending Point."@en ,
                                                                             "Tramo definido por un punto de inicio y fin que puede pertenecer a una o más vías"@es ;
                                                                rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                rdfs:label "Section of Track"@en ,
                                                                           "Tramo"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                   rdfs:comment "Comunidad Autónoma o Ciudad Autónoma"@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                   rdfs:label "Autonomía"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                rdfs:comment "Un barrio es cada una de las partes en que se dividen los pueblos grandes o sus distritos [fuente: Diccionario de la Real Academia (DRAE) 2011]"@es ;
                                                                                rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                rdfs:label "Barrio"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Ciudad
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Ciudad> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio> ;
                                                                                rdfs:comment "Una ciudad es un área urbana en la que predominan fundamentalmente la industria y los servicios [fuente: Wikipedia]"@es ;
                                                                                rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                rdfs:label "Ciudad" .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                  rdfs:comment "Un distrito es cada una de las demarcaciones en que se subdivide un territorio o una población para distribuir y ordenar el ejercicio de los derechos civiles y políticos, o de las funciones públicas, o de los servicios administrativos [fuente: Diccionario de la Real Academia (DRAE) 2011]"@es ;
                                                                                  rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                  rdfs:label "Distrito"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                   rdfs:comment """Un Municipio es el ente local definido en el artículo 140 de la Constitución española y la entidad básica de la organización territorial del Estado según el artículo 1 de la Ley 7/1985, de 2 de abril, Reguladora de las Bases del Régimen Local. Tiene personalidad jurídica y plena capacidad para el cumplimiento de sus fines. La delimitación territorial de Municipio está recogida del REgistro Central de Cartografía del IGN.
Su nombre, que se especifica con la propiedad dct:title, es el proporcionado por el Registro de Entidades Locales del Ministerio de Política Territorial, en http://www.ine.es/nomen2/index.do"""@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                   rdfs:label "Municipio"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Provincia
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Provincia> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                   rdfs:comment """Entidad local con personalidad jurídica propia, determinada por la agrupación de Municipios y división territorial para el cumplimiento de las actividades del Estado. La delimitación territorial de Provincia está recogida en el Registro Central de Cartografía del IGN [fuente: Modelo de Direcciones de la Administración General del Estado v.2]
Su identificador, que se especifica con la propiedad dct:identifier, es el proporcionado por el INE en http://www.ine.es/daco/daco42/codmun/codmun09/09codmun.xls
Su nombre, que se especifica con la propiedad dct:title, es el proporcionado por el Registro de Entidades Locales del Ministerio de Política Territorial, en http://www.ine.es/nomen2/index.do"""@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                   rdfs:label "Provincia" .


###  http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle
<http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle> rdf:type owl:Class ;
                                                                                 rdfs:comment "Dispositivo de transporte autopropulsado, junto con cualquier accesorio, por ejemplo remolques, que es un usuario legal de la red de transporte (Fuente: ISO/TS 19091:2019(en))."@es ,
                                                                                              "Self-propelled transport device, along with any attachments, e.g. trailers, that is a legal user of the transportation network (Source: ISO/TS 19091:2019(en))."@en ;
                                                                                 rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#> ;
                                                                                 rdfs:label "Vehicle"@en ,
                                                                                            "Vehículo"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking> rdf:type owl:Class ;
                                                                                               rdfs:subClassOf :Facility ;
                                                                                               rdfs:comment "Aparcamiento para diferentes tipos de vehículo que incluye instalaciones o superficies de aparcamiento fuera de la vía pública o zonas de aparcamiento en la vía pública para residentes, no residentes o libres."@es ,
                                                                                                            "Parking for different types of vehicles, including off-street parking facilities or on-street parking zones for residents, non-residents, or free parking."@en ;
                                                                                               rdfs:label "Aparcamiento"@es ,
                                                                                                          "Parking"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal> rdf:type owl:Class ;
                                                                                           owl:disjointWith <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via> ;
                                                                                           rdfs:comment "Subacceso independiente exterior (al aire libre) a una misma construcción. Para una misma construcción, con un mismo número de vía, pueden existir varias entradas que pueden estar numeradas con números o letras. [fuente: Modelo de Direcciones de la Administración General del Estado v.2]"@es ;
                                                                                           rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> ;
                                                                                           rdfs:label "Portal" .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via> rdf:type owl:Class ;
                                                                                        rdfs:subClassOf <http://www.geonames.org/ontology#Feature> ,
                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                          owl:onProperty <http://www.geonames.org/ontology#featureClass> ;
                                                                                                          owl:hasValue <http://www.geonames.org/ontology#R>
                                                                                                        ] ,
                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                          owl:onProperty <http://www.geonames.org/ontology#featureCode> ;
                                                                                                          owl:hasValue <http://www.geonames.org/ontology#R.ST>
                                                                                                        ] ;
                                                                                        <http://purl.org/dc/terms/issued> "2013-03-28"^^xsd:dateTime ;
                                                                                        rdfs:comment """Vía de comunicación construida para la circulación. 
En su definición según el modelo de direcciones de la Administración General del Estado, Incluye calles, carreteras de todo tipo, caminos, vías de agua, pantalanes, etc. Asimismo, incluye la pseudovía., es decir todo aquello que complementa o sustituye a la vía.
En nuestro caso, este término se utiliza para hacer referencia a las vías urbanas.

Por esta razón, se utiliza geonames:R.ST como valor principal de la propiedad geonames:featureCode, dejando de lado otras opciones como R.PRMN (promenade), R.TRL (trail). Quizás en el futuro haya que relajar un poco esta opción, sobre todo, por ejemplo, para ciudades con costa y paseo marítimo."""@es ;
                                                                                        rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> ;
                                                                                        rdfs:label "Vía"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal> rdf:type owl:Class ;
                                                                                                           rdfs:comment """Una dirección postal en España. Se define como una especialización de las clases vcard:Address, schema:PostalAddress y locn:Address
Además de las propiedades asociadas a estas clases, y definidas en su correspondiente vocabulario, también se pueden utilizar las definidas en los vocabularios de división administrativa española y en el callejero"""@es ;
                                                                                                           rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal> ;
                                                                                                           rdfs:label "Dirección postal"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#AccessObservation
:AccessObservation rdf:type owl:Class ;
                   rdfs:subClassOf <http://www.w3.org/ns/sosa/Observation> ;
                   rdfs:comment "Observación que se realiza en cualquier acceso a un equipamiento municipal. Incluye acceso de personas o de vehículos."@es ,
                                "Observation carried out at any entrance to a municipal facility. This includes pedestrian or vehicle access."@en ;
                   rdfs:label "Access observation"@en ,
                              "Observación de acceso"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#AccessSensor
:AccessSensor rdf:type owl:Class ;
              rdfs:subClassOf <http://www.w3.org/ns/sosa/Sensor> ;
              rdfs:comment "A device that records the access of people or vehicles. This could be an LPR camera, a building entrance door sensor, or other similar devices."@en ,
                           "Dispositivo que registra el acceso de personas o vehículos. Puede ser una cámara LPR, un sensor de puerta de entrada a un edificio, entre otros."@es ;
              rdfs:label "Access sensor"@en ,
                         "Sensor de acceso"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#CountingObservation
:CountingObservation rdf:type owl:Class ;
                     rdfs:subClassOf <http://www.w3.org/ns/sosa/Observation> ;
                     rdfs:comment "Observación sobre el número de personas o vehículos que cuenta un sensor."@es ,
                                  "Observation on the number of people or vehicles that a sensor counts."@en ;
                     rdfs:label "Counting observation"@en ,
                                "Observación de conteo"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#CountingSensor
:CountingSensor rdf:type owl:Class ;
                rdfs:subClassOf <http://www.w3.org/ns/sosa/Sensor> ;
                rdfs:comment "A device that records the number of people or vehicles that is observes."@en ,
                             "Dispositivo que registra el número de personas o vehículos que observa."@es ;
                rdfs:label "Counting sensor"@en ,
                           "Sensor de conteo"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility
:Facility rdf:type owl:Class ;
          rdfs:subClassOf :InfrastructureElement ;
          rdfs:comment "Hace referencia a edificios de servicios (públicos o privados), zonas de ocio, zonas comerciales o cualquier otro elemento  que afecte directamente a la movilidad, actuando como un foco de atracción de personas o vehículos."@es ,
                       "It refers to service buildings (public or private), leisure areas, commercial areas or any other element that directly affects mobility, acting as a focus of attraction for persons or vehicles."@en ;
          rdfs:label "Equipamiento"@es ,
                     "Facility"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement
:InfrastructureElement rdf:type owl:Class ;
                       rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                       rdfs:comment "Representa el conjunto de todos los elementos de la infraestructura que generan movilidad y elementos urbanos tales como semáforos, señales viales, pilonas, etc."@es ,
                                    "Represents the set of all infrastructure elements that generate mobility and urban elements such as traffic lights, road signs, bollards, etc."@en ;
                       rdfs:label "Elemento de la infraestructura"@es ,
                                  "Infrastructure element"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ManagementRole
:ManagementRole rdf:type owl:Class ;
                rdfs:comment "Rol que realiza la administración municipal o alguna de sus dependencias en la gestión del equipamiento. Puede ser el rol de titularidad, mantenimiento, seguridad, entre otros."@es ,
                             "The role that the municipal administration or one of its departments plays in the management of a municipal facility. This may include ownership, maintenance, security, among others."@en ;
                rdfs:label "Management role"@en ,
                           "Rol de gestión"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ObservationPoint
:ObservationPoint rdf:type owl:Class ;
                  rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                  rdfs:comment "Points where access or counting observations can be made using sensors."@en ,
                               "Puntos en donde se pueden realizar observaciones de acceso o de conteo a través de sensores."@es ;
                  rdfs:label "Observation point"@en ,
                             "Punto de observación"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Organization
:Organization rdf:type owl:Class ;
              rdfs:subClassOf <https://schema.org/Organization> ;
              rdfs:comment "Any public or private organization that owns or manages an element of the infrastructure."@en ,
                           "Cualquier organización pública o privada que sea titular o gestione un elemento de la infraestructura."@es ;
              rdfs:label "Organización"@es ,
                         "Organization"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#UrbanElement
:UrbanElement rdf:type owl:Class ;
              rdfs:subClassOf :InfrastructureElement ;
              rdfs:comment "Comprende el inventario de elementos urbanos tales como señales viales, semáforos, pilonas, etc."@es ,
                           "It includes the inventory of urban elements such as road signs, traffic lights, bollards, etc."@en ;
              rdfs:label "Elemento urbano"@es ,
                         "Urban element"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Violation
:Violation rdf:type owl:Class ;
           rdfs:comment "Incumplimiento o violación de las normas de tránsito o acceso, leyes de circulación u ordenanzas locales por parte de una persona o de un conductor o propietario de un vehículo."@es ,
                        "Non-compliance or violation of traffic or access rules, road laws or local ordinances by a person or a driver or owner of a vehicle."@en ;
           rdfs:label "Infracción"@es ,
                      "Violation"@en .


###  http://www.geonames.org/ontology#Feature
<http://www.geonames.org/ontology#Feature> rdf:type owl:Class .


###  http://www.opengis.net/ont/geosparql#Feature
<http://www.opengis.net/ont/geosparql#Feature> rdf:type owl:Class ;
                                               rdfs:comment "Esta clase representa el tipo \"feature\" de nivel superior. Es equivalente a GFI_Feature, definida en la norma ISO 19156:2011, y es la superclase de todos los tipos de \"feature\"."@es ;
                                               rdfs:isDefinedBy <http://www.opengis.net/spec/geosparql/1.0> ;
                                               rdfs:label "Feature"@en .


###  http://www.opengis.net/ont/geosparql#Geometry
<http://www.opengis.net/ont/geosparql#Geometry> rdf:type owl:Class ;
                                                rdfs:comment "La clase representa el tipo de geometría de nivel superior. Esta clase es equivalente a la clase UML GM_Object definida en la norma ISO 19107 y es la superclase de todos los tipos de geometría."@es ;
                                                rdfs:isDefinedBy <http://www.opengis.net/spec/geosparql/1.0> ,
                                                                 "Geometría"@es ;
                                                rdfs:label "Geometry"@en .


