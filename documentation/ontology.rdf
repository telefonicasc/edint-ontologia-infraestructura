    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://schema.org/address -->


    <owl:ObjectProperty rdf:about="http://schema.org/address">
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal"/>
        <rdfs:comment xml:lang="es">Dirección física de la entidad,</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://schema.org"/>
        <rdfs:label xml:lang="en">address</rdfs:label>
        <rdfs:label xml:lang="en">dirección</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://schema.org/manufacturer -->


    <owl:ObjectProperty rdf:about="http://schema.org/manufacturer">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#DispositivoMedicionTrafico"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#AccessSensor"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#CountingSensor"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://schema.org/Organization"/>
        <rdfs:comment xml:lang="es">El fabricante del producto.</rdfs:comment>
        <rdfs:comment xml:lang="en">The manufacturer of the product.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://schema.org/"/>
        <rdfs:label xml:lang="es">fabricante</rdfs:label>
        <rdfs:label xml:lang="en">manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#finTramo -->


    <owl:ObjectProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#finTramo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/sf#Point"/>
        <rdfs:comment xml:lang="es">Relación del tramo con el lugar donde finaliza el tramo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship of the section with the point where it ends.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Fin del Tramo</rdfs:label>
        <rdfs:label xml:lang="en">Section end</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#incidenciaEnTramo -->


    <owl:ObjectProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#incidenciaEnTramo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia"/>
        <rdfs:range rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo"/>
        <rdfs:comment xml:lang="es">Relación de la Incidencia con el Tramo donde se produce la misma.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship of the Incidence withe the  Section, where it happens.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="en">Incidence in Section</rdfs:label>
        <rdfs:label xml:lang="es">Incidencia en tramo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo -->


    <owl:ObjectProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/sf#Point"/>
        <rdfs:comment xml:lang="es">Relación del tramo con el lugar donde se inicia el tramo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship of the section with the point where it starts.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Inicio del Tramo</rdfs:label>
        <rdfs:label xml:lang="en">Section start</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#monitorea -->


    <owl:ObjectProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#monitorea">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico"/>
        <rdfs:range rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo"/>
        <rdfs:comment xml:lang="es">Relación del Equipo de Tráfico con el Tramo que monitorea</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between Traffic Equipment and the Section it monitors</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Monitorea</rdfs:label>
        <rdfs:label xml:lang="en">Monitors</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#tipoEquipoTrafico -->


    <owl:ObjectProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#tipoEquipoTrafico">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/sector-publico/transporte/tipo-equipo-trafico"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Tipo de equipo de tráfico, equipos de control y dispositivos de medición</rdfs:comment>
        <rdfs:comment xml:lang="en">Type of traffic equipment, monitor equipment or meassuring devices</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Tipo de Equipo de Tráfico</rdfs:label>
        <rdfs:label xml:lang="en">Type of Traffic Equipment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#tipoIncidencia -->


    <owl:ObjectProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#tipoIncidencia">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/sector-publico/transporte/tipo-incidencia"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Tipo de incidencia, pueden ser planificadas o no planificadas.</rdfs:comment>
        <rdfs:comment xml:lang="en">Type of incidence, planned or unplannedt</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Tipo de Incidencia</rdfs:label>
        <rdfs:label xml:lang="en">Type of Incidence</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio">
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio"/>
        <rdfs:comment xml:lang="es">Municipio al que pertenece un fenómeno geográfico o una entidad administrativa</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label xml:lang="es">pertenece a municipio</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contienePortal -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contienePortal">
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal"/>
        <rdfs:comment xml:lang="es">Portal que un fenómeno geográfico contiene (por ejemplo, una vía o un tramo de vía, aunque también puede ser un barrio, distrito, ciudad, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero"/>
        <rdfs:label xml:lang="es">contiene portal</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contieneVia -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contieneVia">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#sfContains"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via"/>
        <terms:issued>2014-03-28</terms:issued>
        <rdfs:comment xml:lang="es">Vía que un fenómeno geográfico contiene (por ejemplo, un barrio, distrito, ciudad, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero"/>
        <rdfs:label xml:lang="es">contiene vía</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#belongsTo -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#belongsTo">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ObservationPoint"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Ciudad"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Provincia"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Relación entre un elemento de infraestructura y la división administrativa a la cual pertenece, incluido un Barrio.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between an infrastructure element and the administrative division to which it belongs, including a neighborhood.</rdfs:comment>
        <rdfs:label xml:lang="en">belongs to</rdfs:label>
        <rdfs:label xml:lang="es">pertenece a</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#containsFacility -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#containsFacility">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility"/>
        <rdfs:comment xml:lang="en">A  facility may contain other facilities. For example, a cultural center may contain exhibition halls, auditoriums, etc.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un equipamiento  puede contener otros equipamientos. Por ejemplo, un centro cultural puede contener salas de exposiciòn, auditorios, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">contains facility</rdfs:label>
        <rdfs:label xml:lang="es">contiene equipamiento</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasInfrastructureType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasInfrastructureType">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement"/>
        <rdfs:comment xml:lang="es">Relación entre un elemento de infraestructura y un concepto de la taxonomía de tipos de elemento de infraestructura.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between an infrastructure element and a concept from the taxonomy of infrastructure element types.</rdfs:comment>
        <rdfs:label xml:lang="en">has infrastructure element type</rdfs:label>
        <rdfs:label xml:lang="es">tiene tipo de elemento de infraestructura</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasObservationPoint -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasObservationPoint">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ObservationPoint"/>
        <rdfs:comment xml:lang="es">Relación entre un elemento de la infraestructura y un punto de observación.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between an infrastructure element and an observation point.</rdfs:comment>
        <rdfs:label xml:lang="en">has observation point</rdfs:label>
        <rdfs:label xml:lang="es">tiene punto de observación</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasRegisteredOwner -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasRegisteredOwner">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Organization"/>
        <rdfs:comment xml:lang="en">Relación entre un elemento de infraestructura y su titular, generalmente una organización</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between an infrastructure element and its owner, which is usually an organization.</rdfs:comment>
        <rdfs:label xml:lang="en">has registered owner</rdfs:label>
        <rdfs:label xml:lang="es">tiene titular registrado</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasRoleType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasRoleType">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ManagementRole"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/RoleType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Relación entre el Rol de gestión y la taxonomía de roles de gestión.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between the management role and the taxonomy of management roles.</rdfs:comment>
        <rdfs:label xml:lang="en">has role type</rdfs:label>
        <rdfs:label xml:lang="es">tiene tipo de rol</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasViolationType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#hasViolationType">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Violation"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/ViolationType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Relaciona a una Infracción con un concepto de la taxonomía de tipos de infracción.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relate an Infraction to a concept from the taxonomy of infraction types.</rdfs:comment>
        <rdfs:label xml:lang="en">has violation type</rdfs:label>
        <rdfs:label xml:lang="es">tiene tipo de infracción</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#includesVehicle -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#includesVehicle">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#AccessObservation"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle"/>
        <rdfs:comment xml:lang="en">Property that connects an observation to the observed vehicle.</rdfs:comment>
        <rdfs:comment xml:lang="es">Propiedad que relaciona una observación con el vehículo observado</rdfs:comment>
        <rdfs:label xml:lang="en">includes vehicle</rdfs:label>
        <rdfs:label xml:lang="es">incluye vehículo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#linkedTo -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#linkedTo">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Violation"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle"/>
        <rdfs:comment xml:lang="es">Relación entre una infracción y el vehículo que cometió la infracción.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between an infraction and the vehicle that committed the infraction.</rdfs:comment>
        <rdfs:label xml:lang="es">asociado a</rdfs:label>
        <rdfs:label xml:lang="en">linked to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#madeOnInfrastructure -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#madeOnInfrastructure">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ManagementRole"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement"/>
        <rdfs:comment xml:lang="es">Relación entre el rol de gestion que ejerce una organización  y el elemento de infraestructura sobre el cual se realiza la gestión.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between the management role exercised by an organization and the infrastructure element on which the management is carried out.</rdfs:comment>
        <rdfs:label xml:lang="en">made on an infrastructure element</rdfs:label>
        <rdfs:label xml:lang="es">realizado sobre elemento de infraestructura</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#offersRegularActivity -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#offersRegularActivity">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/RegularActivity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Actividad que se lleva a cabo regularmente en el equipamiento.</rdfs:comment>
        <rdfs:comment xml:lang="en">Activity that is carried out regularly in a facility.</rdfs:comment>
        <rdfs:label xml:lang="en">offers regular activity</rdfs:label>
        <rdfs:label xml:lang="es">ofrece actividad regular</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#provesViolation -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#provesViolation">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#AccessObservation"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Violation"/>
        <rdfs:comment xml:lang="es">Relación entre la observación urbana y la infracción que está soportando.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between an observation and the infraction it is proving.</rdfs:comment>
        <rdfs:label xml:lang="es">demuestra infracción</rdfs:label>
        <rdfs:label xml:lang="en">proofs violation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#providesPublicService -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#providesPublicService">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/PublicService"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Public service provided by a facility, for example internet via wifi.</rdfs:comment>
        <rdfs:comment xml:lang="es">Servicio público prestado por un equipamiento, por ejemplo internet a través de una wifi.</rdfs:comment>
        <rdfs:label xml:lang="es">presta servicio público</rdfs:label>
        <rdfs:label xml:lang="en">provides public service</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#rolePlayedBy -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#rolePlayedBy">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ManagementRole"/>
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Organization"/>
        <rdfs:comment xml:lang="es">Relación entre el rol de gestión sobre un equipamiento municipal y la organización que lo ejerce.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship between the management role over a municipal facility and the organization that exercises it.</rdfs:comment>
        <rdfs:label xml:lang="es">rol ejercido por</rdfs:label>
        <rdfs:label xml:lang="en">role played by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.geonames.org/ontology#featureClass -->


    <owl:ObjectProperty rdf:about="http://www.geonames.org/ontology#featureClass"/>
    


    <!-- http://www.geonames.org/ontology#featureCode -->


    <owl:ObjectProperty rdf:about="http://www.geonames.org/ontology#featureCode"/>
    


    <!-- http://www.opengis.net/ont/geosparql#hasGeometry -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasGeometry">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:comment xml:lang="es">Una representación espacial de un &quot;feature&quot; determinado.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0"/>
        <rdfs:label xml:lang="en">has geometry</rdfs:label>
        <rdfs:label xml:lang="es">tiene geometría</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#sfContains -->


    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#sfContains"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasBeginning -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasBeginning">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2006/time#hasTime"/>
        <rdfs:comment xml:lang="en">Beginning of a temporal entity</rdfs:comment>
        <rdfs:comment xml:lang="es">Comienzo de una entidad temporal.</rdfs:comment>
        <rdfs:label xml:lang="en">has beginning</rdfs:label>
        <rdfs:label xml:lang="es">tiene principio</rdfs:label>
        <skos:definition xml:lang="en">Beginning of a temporal entity.</skos:definition>
        <skos:definition xml:lang="es">Comienzo de una entidad temporal.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasEnd -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasEnd">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2006/time#hasTime"/>
        <rdfs:comment xml:lang="en">End of a temporal entity.</rdfs:comment>
        <rdfs:comment xml:lang="es">Final de una entidad temporal.</rdfs:comment>
        <rdfs:label xml:lang="en">has end</rdfs:label>
        <rdfs:label xml:lang="es">tiene fin</rdfs:label>
        <skos:definition xml:lang="en">End of a temporal entity.</skos:definition>
        <skos:definition xml:lang="es">Final de una entidad temporal.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasTime -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasTime"/>
    


    <!-- http://www.w3.org/ns/sosa/hasFeatureOfInterest -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/hasFeatureOfInterest">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
        <rdfs:comment xml:lang="es">Una relación entre una Observación y la entidad cuya calidad fue observada, o entre una Actuación y la entidad cuya propiedad fue modificada, o entre un acto de muestreo y la entidad que fue muestreada.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:label xml:lang="es">tiene entidad de interés</rdfs:label>
        <rdfs:label>has feature of interest</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/madeBySensor -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/madeBySensor">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment xml:lang="es">Relación entre una observación y el sensor que realiza la observación.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:label xml:lang="en">made by sensor or observer</rdfs:label>
        <rdfs:label xml:lang="es">realizado por sensor u observador</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/observedProperty -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/observedProperty">
        <owl:inverseOf rdf:resource="http://www.w3.org/ns/sosa/wasObservedBy"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/ObservationCollection"/>
        <schema:rangeIncludes rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <schema:rangeIncludes rdf:resource="http://www.w3.org/ns/sosa/Property"/>
        <rdfs:comment xml:lang="en">Relation linking an Observation to the property that was observed. The ObservableProperty should be a property of the FeatureOfInterest (linked by hasFeatureOfInterest) of this Observation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/obs/"/>
        <rdfs:label xml:lang="en">observed property</rdfs:label>
        <skos:definition xml:lang="en">
  relation from an Observation or ObservationCollection to the property that was observed
  </skos:definition>
        <skos:definition xml:lang="en">Relation linking an Observation to the property that was observed. The ObservableProperty should be a property of the FeatureOfInterest (linked by hasFeatureOfInterest) of this Observation.</skos:definition>
        <skos:note xml:lang="en">
  &apos;observed property&apos; covers the concepts referred to in [VIM] as &apos;measurand&apos; (quantitative values) and &apos;examinand&apos; (categorical and nominal values — [VIM4]), as well as complex and structured properties whose values may be represented as lists, vectors, arrays, rasters, geometries, etc. More specific terms are used in other contexts for related concepts, such as &apos;analyte&apos; (chemistry) and &apos;determinand&apos; (water quality).
  </skos:note>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/observes -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/observes">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <rdfs:comment xml:lang="es">Relación entre un sensor y una propiedad observable que es capaz de detectar.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:label xml:lang="es">observa</rdfs:label>
        <rdfs:label xml:lang="en">observes</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/phenomenonTime -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/phenomenonTime">
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/Actuation"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/ObservationCollection"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/Sampling"/>
        <rdfs:comment xml:lang="es">El momento en que el resultado de una observación, actuación o muestreo se aplica a la entidad de interés. No necesariamente coincide con el momento del resultado. Puede ser un intervalo, un instante o alguna otra entidad temporal compuesta.</rdfs:comment>
        <rdfs:comment xml:lang="en">The time that the Result of an Observation, Actuation or Sampling applies to the FeatureOfInterest. Not necessarily the same as the resultTime. May be an Interval or an Instant, or some other compound TemporalEntity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/common/"/>
        <rdfs:label xml:lang="es">momento del fenómeno</rdfs:label>
        <rdfs:label xml:lang="en">phenomenon time</rdfs:label>
        <skos:definition xml:lang="en">The time that the Result of an Observation, Actuation or Sampling applies to the FeatureOfInterest. Not necessarily the same as the resultTime. May be an Interval or an Instant, or some other compound TemporalEntity.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/ns/sosa/wasObservedBy -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/wasObservedBy">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/identifier -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/identifier">
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment xml:lang="en">An unambiguous reference to the resource within a given context.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una referencia no ambigüa al recurso dentro de un contexto determinado.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:label xml:lang="es">identificador</rdfs:label>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/endDate -->


    <owl:DatatypeProperty rdf:about="http://schema.org/endDate">
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">La fecha y hora de finalización del elemento (en formato de fecha ISO 8601).</rdfs:comment>
        <rdfs:comment xml:lang="en">The end date and time of the item (in ISO 8601 date format).</rdfs:comment>
        <rdfs:comment xml:lang="en">end date</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://schema.org"/>
        <rdfs:label xml:lang="es">fecha de finalización</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/openingHours -->


    <owl:DatatypeProperty rdf:about="http://schema.org/openingHours">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Horario general de apertura de un negocio. El horario se puede especificar como un rango semanal, comenzando por días y luego por horas al día. Se pueden indicar varios días separados por comas (&quot;,&quot;). Los rangos de días u horas se especifican con un guion (-).</rdfs:comment>
        <rdfs:comment xml:lang="en">The general opening hours for a business. Opening hours can be specified as a weekly time range, starting with days, then times per day. Multiple days can be listed with commas &apos;,&apos; separating each day. Day or time ranges are specified using a hyphen &apos;-&apos;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://schema.org"/>
        <rdfs:label xml:lang="es">horario de apertura</rdfs:label>
        <rdfs:label xml:lang="en">opening hours</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/startDate -->


    <owl:DatatypeProperty rdf:about="http://schema.org/startDate">
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">La fecha y hora de inicio del elemento (en formato de fecha ISO 8601).</rdfs:comment>
        <rdfs:comment xml:lang="en">The start date and time of the item (in ISO 8601 date format).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://schema.org"/>
        <rdfs:label xml:lang="es">fecha de inicio</rdfs:label>
        <rdfs:label xml:lang="en">start date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#enServicio -->


    <owl:DatatypeProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#enServicio">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#DispositivoMedicionTrafico"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Esta propiedad permite conocer si el dispositivo funciona o no.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows describing whether the device is working or not.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">En Servicio</rdfs:label>
        <rdfs:label xml:lang="en">Running device</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#esRecurrente -->


    <owl:DatatypeProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#esRecurrente">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaPlanificada"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Esta propiedad permite describir si la incidencia es recurrente o no.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows describing whether there is a recurrence in the incidence or not</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#"/>
        <rdfs:label xml:lang="es">Incidencia recurrente</rdfs:label>
        <rdfs:label xml:lang="en">Recurrent incidence</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#fechaFinPrevista -->


    <owl:DatatypeProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#fechaFinPrevista">
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaPlanificada"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="es">La fecha y hora prevista de
	finalización de una incidencia planificada (en formato fecha ISO 8601)</rdfs:comment>
        <rdfs:comment xml:lang="en">The end date and time of a planned incidence (in ISO 8601 date format).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico/"/>
        <rdfs:label xml:lang="en">(expected) end date</rdfs:label>
        <rdfs:label xml:lang="es">fecha de fin (prevista)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#frecuenciaMedicion -->


    <owl:DatatypeProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#frecuenciaMedicion">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#DispositivoMedicionTrafico"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Esta propiedad permite conocer la frecuencia de medición del dispositivo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows to know the measurement frequency of the device.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#"/>
        <rdfs:label xml:lang="es">Frecuencia Medición</rdfs:label>
        <rdfs:label xml:lang="en">Measurement Frequency</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#incidenciaAdjunto -->


    <owl:DatatypeProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#incidenciaAdjunto">
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">A document where more information about the incidence can be found.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un documento donde se puede consultar la información sobre la incidencia.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">adjunto a la incidencia</rdfs:label>
        <rdfs:label xml:lang="en">attached to incidence</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#numSentidos -->


    <owl:DatatypeProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#numSentidos">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico"/>
                    <rdf:Description rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Number of directions of traffic</rdfs:comment>
        <rdfs:comment xml:lang="es">Número de sentidos de circulación</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Sentidos de circulación</rdfs:label>
        <rdfs:label xml:lang="en">Street directions</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#recurrencia -->


    <owl:DatatypeProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#recurrencia">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaPlanificada"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Esta propiedad permite describir la recurrencia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows describing the recurrence</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#"/>
        <rdfs:label xml:lang="en">Recurrence</rdfs:label>
        <rdfs:label xml:lang="es">Recurrencia</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#unidadMedida -->


    <owl:DatatypeProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#unidadMedida">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">En el caso del nivel del servicio, las medidas posibles son: verde o fluido; amarillo o lento; naranja o denso; rojo o congestión; negro o circulación interrumpida; gris o sin datos.</rdfs:comment>
        <rdfs:comment xml:lang="es">Esta propiedad permite describir la unidad de medida de la medición del Dispositivo de Medición de Tráfico.</rdfs:comment>
        <rdfs:comment xml:lang="en">In the case of the Service level (nivel), the possible measures are: green or fluid; yellow or slow; orange or dense; red or congestion; black or interrupted circulation; grey or no data.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows describing the unit of measurement of the Trafic Monitoring Device</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#"/>
        <rdfs:label xml:lang="es">Unidad de Medida</rdfs:label>
        <rdfs:label xml:lang="en">Unit of Measurement</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#urbano -->


    <owl:DatatypeProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#urbano">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Esta propiedad permite describir si el dispositivo es urbano o no.</rdfs:comment>
        <rdfs:comment xml:lang="en">This property allows knowing whether the device is urban or not</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#"/>
        <rdfs:label xml:lang="en">Urban</rdfs:label>
        <rdfs:label xml:lang="es">Urbano</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#validada -->


    <owl:DatatypeProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#validada">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#ObservacionTrafico"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Esta propiedad permite conocer si se ha producido una validación de la observación o no</rdfs:comment>
        <rdfs:comment xml:lang="en">This property states whether the observation is validated or not.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#"/>
        <rdfs:label xml:lang="es">Validada</rdfs:label>
        <rdfs:label xml:lang="en">Validated Observation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#complaintCancelled -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#complaintCancelled">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Violation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="es">Propiedad que indica si la denuncia (de una infracción) ha sido anulada o no</rdfs:comment>
        <rdfs:label xml:lang="en">cancelled complaint</rdfs:label>
        <rdfs:label xml:lang="es">denuncia anulada</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#installationDate -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#installationDate">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#UrbanElement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Date when an entity, especially a device, was installed.</rdfs:comment>
        <rdfs:comment xml:lang="es">Fecha en la que se instaló una entidad, especialmente un dispositivo</rdfs:comment>
        <rdfs:label xml:lang="es">fecha de instalación</rdfs:label>
        <rdfs:label xml:lang="en">installation date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#isPublic -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#isPublic">
        <rdfs:domain rdf:resource="https://schema.org/Organization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Property that points out whether an entity, especially an organization, is public or not.</rdfs:comment>
        <rdfs:comment xml:lang="es">Propiedad que indica si una entidad, especialmente una Organización, es pública</rdfs:comment>
        <rdfs:label xml:lang="es">es público</rdfs:label>
        <rdfs:label xml:lang="en">is public</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#maintenanceDate -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#maintenanceDate">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#UrbanElement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Date when an entity was last maintained, especially an urban element.</rdfs:comment>
        <rdfs:comment xml:lang="es">Fecha en la que se hizo mantenimiento de una entidad por última vez, especialmente un elemento urbano.</rdfs:comment>
        <rdfs:label xml:lang="es">fecha de mantenimiento</rdfs:label>
        <rdfs:label xml:lang="en">maintenance date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/2006/time#inXSDgYearMonth -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/2006/time#inXSDgYearMonth">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYearMonth"/>
        <rdfs:comment xml:lang="es">Posición de un instante, expresado utilizando xsd:gYearMonth.</rdfs:comment>
        <rdfs:comment xml:lang="en">Position of an instant, expressed using xsd:gYearMonth</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2006/time#"/>
        <rdfs:label xml:lang="es">en año-mes gregoriano XSD</rdfs:label>
        <rdfs:label xml:lang="en">in XSD g-YearMonth</rdfs:label>
        <skos:definition xml:lang="es">Posición de un instante, expresado utilizando xsd:gYearMonth.</skos:definition>
        <skos:definition xml:lang="en">Position of an instant, expressed using xsd:gYearMonth</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/sosa/hasSimpleResult -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/sosa/hasSimpleResult">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/Actuation"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/ObservationCollection"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/Sampling"/>
        <rdfs:comment xml:lang="en">The simple value of an Observation or Actuation or act of Sampling.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/common/"/>
        <rdfs:label xml:lang="en">has simple result</rdfs:label>
        <skos:definition xml:lang="en">The simple value of an Observation or Actuation or act of Sampling.</skos:definition>
        <skos:example xml:lang="en">For instance, the values 23 or true.</skos:example>
    </owl:DatatypeProperty>
    


    <!-- http://www.w3.org/ns/sosa/resultTime -->


    <owl:DatatypeProperty rdf:about="http://www.w3.org/ns/sosa/resultTime">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/Actuation"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/ObservationCollection"/>
        <schema:domainIncludes rdf:resource="http://www.w3.org/ns/sosa/Sampling"/>
        <rdfs:comment xml:lang="en">The result time is the instant of time when the Observation, Actuation or Sampling activity was completed.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/common/"/>
        <rdfs:label xml:lang="en">result time</rdfs:label>
        <skos:definition xml:lang="en">The result time is the instant of time when the Observation, Actuation or Sampling activity was completed.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://datos.ign.es/def/geo_core#xETRS89 -->


    <owl:DatatypeProperty rdf:about="https://datos.ign.es/def/geo_core#xETRS89">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/sf#Point"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:source xml:lang="es">Catálogo de Objetos Geográficos BTN100.</dc:source>
        <rdfs:comment xml:lang="es">Coordenada X en metros (ETRS89)</rdfs:comment>
        <rdfs:comment xml:lang="en">X-Coordinate in meters (ETRS89)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://datos.ign.es/def/geo_core#"/>
        <rdfs:label>xETRS89</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://datos.ign.es/def/geo_core#yETRS89 -->


    <owl:DatatypeProperty rdf:about="https://datos.ign.es/def/geo_core#yETRS89">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/sf#Point"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:source xml:lang="es">Catálogo de Objetos Geográficos BTN100.</dc:source>
        <rdfs:comment xml:lang="es">Coordenada Y en metros (ETRS89)</rdfs:comment>
        <rdfs:comment xml:lang="en">Y-Coordinate in meters (ETRS89)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://datos.ign.es/def/geo_core#"/>
        <rdfs:label>yETRS89</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/bicicleta-publica#EstacionBicicleta -->


    <owl:Class rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/bicicleta-publica#EstacionBicicleta">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility"/>
        <rdfs:comment xml:lang="es">Lugar donde se puede tanto dejar como recoger las bicicletas. Está compuesto de anclajes</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/bicicleta-publica"/>
        <rdfs:label xml:lang="es">Estación de bicicletas</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#DispositivoMedicionTrafico -->


    <owl:Class rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#DispositivoMedicionTrafico">
        <rdfs:subClassOf rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment xml:lang="es">Dispositivo de Medición de Tráfico, tipo de equipo de tráfico que realiza mediciones.</rdfs:comment>
        <rdfs:comment xml:lang="en">Traffic Measuring Device, type of Traffic Device which performs measurements.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Dispositivo de medición de tráfico</rdfs:label>
        <rdfs:label xml:lang="en">Traffic Measuring Device</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico -->


    <owl:Class rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <owl:disjointWith rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia"/>
        <owl:disjointWith rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo"/>
        <rdfs:comment xml:lang="en">A traffic equipment monitors the traffic of a city</rdfs:comment>
        <rdfs:comment xml:lang="es">Un Equipo de Tráfico es uno de los equipos que se encargan de controlar o monitorizar el tráfico de la ciudad.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Equipo de tráfico</rdfs:label>
        <rdfs:label xml:lang="en">Traffic equipment</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia -->


    <owl:Class rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <owl:disjointWith rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo"/>
        <rdfs:comment xml:lang="en">Incidence in the traffic system of a city</rdfs:comment>
        <rdfs:comment xml:lang="es">Incidencia que ocurre en el sistema de tráfico de una ciudad</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="en">Incidence</rdfs:label>
        <rdfs:label xml:lang="es">Incidencia</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaNoPlanificada -->


    <owl:Class rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaNoPlanificada">
        <rdfs:subClassOf rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia"/>
        <rdfs:comment xml:lang="es">Incidencia no planificada del tráfico de una ciudad</rdfs:comment>
        <rdfs:comment xml:lang="en">Unplanned traffic incidence</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Incidencia no planificada</rdfs:label>
        <rdfs:label xml:lang="en">Unplanned incidence</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaPlanificada -->


    <owl:Class rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaPlanificada">
        <rdfs:subClassOf rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia"/>
        <rdfs:comment xml:lang="es">Incidencia planificada, puede ser recurrente o no</rdfs:comment>
        <rdfs:comment xml:lang="en">Planned traffic incidence</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Incidencia planificada</rdfs:label>
        <rdfs:label xml:lang="en">Planned incidence</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#ObservacionTrafico -->


    <owl:Class rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#ObservacionTrafico">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:comment xml:lang="es">Observación realizada por un Dispositivo de Medición de Tráfico</rdfs:comment>
        <rdfs:comment xml:lang="en">Observation by a Traffic Measuring Device</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Observación del tráfico</rdfs:label>
        <rdfs:label xml:lang="en">Traffic monitoring</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico -->


    <owl:Class rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <rdfs:comment xml:lang="en">Property of the Meassurement of Traffic: composition, load, occupation, intensity, level or speed.</rdfs:comment>
        <rdfs:comment xml:lang="es">Propiedad de la Medición de Tráfico: composición, carga, ocupación, intensidad, nivel o velocidad.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Propiedad Medición Tráfico</rdfs:label>
        <rdfs:label xml:lang="en">Traffic meassuring property</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo -->


    <owl:Class rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="en">Section/s of a Track defined by a starting and an ending Point.</rdfs:comment>
        <rdfs:comment xml:lang="es">Tramo definido por un punto de inicio y fin que puede pertenecer a una o más vías</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="en">Section of Track</rdfs:label>
        <rdfs:label xml:lang="es">Tramo</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="es">Comunidad Autónoma o Ciudad Autónoma</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label xml:lang="es">Autonomía</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="es">Un barrio es cada una de las partes en que se dividen los pueblos grandes o sus distritos [fuente: Diccionario de la Real Academia (DRAE) 2011]</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label xml:lang="es">Barrio</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Ciudad -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Ciudad">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio"/>
        <rdfs:comment xml:lang="es">Una ciudad es un área urbana en la que predominan fundamentalmente la industria y los servicios [fuente: Wikipedia]</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label>Ciudad</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="es">Un distrito es cada una de las demarcaciones en que se subdivide un territorio o una población para distribuir y ordenar el ejercicio de los derechos civiles y políticos, o de las funciones públicas, o de los servicios administrativos [fuente: Diccionario de la Real Academia (DRAE) 2011]</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label xml:lang="es">Distrito</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="es">Un Municipio es el ente local definido en el artículo 140 de la Constitución española y la entidad básica de la organización territorial del Estado según el artículo 1 de la Ley 7/1985, de 2 de abril, Reguladora de las Bases del Régimen Local. Tiene personalidad jurídica y plena capacidad para el cumplimiento de sus fines. La delimitación territorial de Municipio está recogida del REgistro Central de Cartografía del IGN.
Su nombre, que se especifica con la propiedad dct:title, es el proporcionado por el Registro de Entidades Locales del Ministerio de Política Territorial, en http://www.ine.es/nomen2/index.do</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label xml:lang="es">Municipio</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Provincia -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Provincia">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="es">Entidad local con personalidad jurídica propia, determinada por la agrupación de Municipios y división territorial para el cumplimiento de las actividades del Estado. La delimitación territorial de Provincia está recogida en el Registro Central de Cartografía del IGN [fuente: Modelo de Direcciones de la Administración General del Estado v.2]
Su identificador, que se especifica con la propiedad dct:identifier, es el proporcionado por el INE en http://www.ine.es/daco/daco42/codmun/codmun09/09codmun.xls
Su nombre, que se especifica con la propiedad dct:title, es el proporcionado por el Registro de Entidades Locales del Ministerio de Política Territorial, en http://www.ine.es/nomen2/index.do</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label>Provincia</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle">
        <rdfs:comment xml:lang="es">Dispositivo de transporte autopropulsado, junto con cualquier accesorio, por ejemplo remolques, que es un usuario legal de la red de transporte (Fuente: ISO/TS 19091:2019(en)).</rdfs:comment>
        <rdfs:comment xml:lang="en">Self-propelled transport device, along with any attachments, e.g. trailers, that is a legal user of the transportation network (Source: ISO/TS 19091:2019(en)).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#"/>
        <rdfs:label xml:lang="en">Vehicle</rdfs:label>
        <rdfs:label xml:lang="es">Vehículo</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility"/>
        <rdfs:comment xml:lang="es">Aparcamiento para diferentes tipos de vehículo que incluye instalaciones o superficies de aparcamiento fuera de la vía pública o zonas de aparcamiento en la vía pública para residentes, no residentes o libres.</rdfs:comment>
        <rdfs:comment xml:lang="en">Parking for different types of vehicles, including off-street parking facilities or on-street parking zones for residents, non-residents, or free parking.</rdfs:comment>
        <rdfs:label xml:lang="es">Aparcamiento</rdfs:label>
        <rdfs:label xml:lang="en">Parking</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal">
        <owl:disjointWith rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via"/>
        <rdfs:comment xml:lang="es">Subacceso independiente exterior (al aire libre) a una misma construcción. Para una misma construcción, con un mismo número de vía, pueden existir varias entradas que pueden estar numeradas con números o letras. [fuente: Modelo de Direcciones de la Administración General del Estado v.2]</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero"/>
        <rdfs:label>Portal</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via">
        <rdfs:subClassOf rdf:resource="http://www.geonames.org/ontology#Feature"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.geonames.org/ontology#featureClass"/>
                <owl:hasValue rdf:resource="http://www.geonames.org/ontology#R"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.geonames.org/ontology#featureCode"/>
                <owl:hasValue rdf:resource="http://www.geonames.org/ontology#R.ST"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2013-03-28</terms:issued>
        <rdfs:comment xml:lang="es">Vía de comunicación construida para la circulación. 
En su definición según el modelo de direcciones de la Administración General del Estado, Incluye calles, carreteras de todo tipo, caminos, vías de agua, pantalanes, etc. Asimismo, incluye la pseudovía., es decir todo aquello que complementa o sustituye a la vía.
En nuestro caso, este término se utiliza para hacer referencia a las vías urbanas.

Por esta razón, se utiliza geonames:R.ST como valor principal de la propiedad geonames:featureCode, dejando de lado otras opciones como R.PRMN (promenade), R.TRL (trail). Quizás en el futuro haya que relajar un poco esta opción, sobre todo, por ejemplo, para ciudades con costa y paseo marítimo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero"/>
        <rdfs:label xml:lang="es">Vía</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal">
        <rdfs:comment xml:lang="es">Una dirección postal en España. Se define como una especialización de las clases vcard:Address, schema:PostalAddress y locn:Address
Además de las propiedades asociadas a estas clases, y definidas en su correspondiente vocabulario, también se pueden utilizar las definidas en los vocabularios de división administrativa española y en el callejero</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal"/>
        <rdfs:label xml:lang="es">Dirección postal</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#AccessObservation -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#AccessObservation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:comment xml:lang="es">Observación que se realiza en cualquier acceso a un equipamiento municipal. Incluye acceso de personas o de vehículos.</rdfs:comment>
        <rdfs:comment xml:lang="en">Observation carried out at any entrance to a municipal facility. This includes pedestrian or vehicle access.</rdfs:comment>
        <rdfs:label xml:lang="en">Access observation</rdfs:label>
        <rdfs:label xml:lang="es">Observación de acceso</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#AccessSensor -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#AccessSensor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment xml:lang="en">A device that records the access of people or vehicles. This could be an LPR camera, a building entrance door sensor, or other similar devices.</rdfs:comment>
        <rdfs:comment xml:lang="es">Dispositivo que registra el acceso de personas o vehículos. Puede ser una cámara LPR, un sensor de puerta de entrada a un edificio, entre otros.</rdfs:comment>
        <rdfs:label xml:lang="en">Access sensor</rdfs:label>
        <rdfs:label xml:lang="es">Sensor de acceso</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#CountingObservation -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#CountingObservation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:comment xml:lang="es">Observación sobre el número de personas o vehículos que cuenta un sensor.</rdfs:comment>
        <rdfs:comment xml:lang="en">Observation on the number of people or vehicles that a sensor counts.</rdfs:comment>
        <rdfs:label xml:lang="en">Counting observation</rdfs:label>
        <rdfs:label xml:lang="es">Observación de conteo</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#CountingSensor -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#CountingSensor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:comment xml:lang="en">A device that records the number of people or vehicles that is observes.</rdfs:comment>
        <rdfs:comment xml:lang="es">Dispositivo que registra el número de personas o vehículos que observa.</rdfs:comment>
        <rdfs:label xml:lang="en">Counting sensor</rdfs:label>
        <rdfs:label xml:lang="es">Sensor de conteo</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Facility">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement"/>
        <rdfs:comment xml:lang="es">Hace referencia a edificios de servicios (públicos o privados), zonas de ocio, zonas comerciales o cualquier otro elemento  que afecte directamente a la movilidad, actuando como un foco de atracción de personas o vehículos.</rdfs:comment>
        <rdfs:comment xml:lang="en">It refers to service buildings (public or private), leisure areas, commercial areas or any other element that directly affects mobility, acting as a focus of attraction for persons or vehicles.</rdfs:comment>
        <rdfs:label xml:lang="es">Equipamiento</rdfs:label>
        <rdfs:label xml:lang="en">Facility</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="es">Representa el conjunto de todos los elementos de la infraestructura que generan movilidad y elementos urbanos tales como semáforos, señales viales, pilonas, etc.</rdfs:comment>
        <rdfs:comment xml:lang="en">Represents the set of all infrastructure elements that generate mobility and urban elements such as traffic lights, road signs, bollards, etc.</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento de la infraestructura</rdfs:label>
        <rdfs:label xml:lang="en">Infrastructure element</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ManagementRole -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ManagementRole">
        <rdfs:comment xml:lang="es">Rol que realiza la administración municipal o alguna de sus dependencias en la gestión del equipamiento. Puede ser el rol de titularidad, mantenimiento, seguridad, entre otros.</rdfs:comment>
        <rdfs:comment xml:lang="en">The role that the municipal administration or one of its departments plays in the management of a municipal facility. This may include ownership, maintenance, security, among others.</rdfs:comment>
        <rdfs:label xml:lang="en">Management role</rdfs:label>
        <rdfs:label xml:lang="es">Rol de gestión</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ObservationPoint -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#ObservationPoint">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:comment xml:lang="en">Points where access or counting observations can be made using sensors.</rdfs:comment>
        <rdfs:comment xml:lang="es">Puntos en donde se pueden realizar observaciones de acceso o de conteo a través de sensores.</rdfs:comment>
        <rdfs:label xml:lang="en">Observation point</rdfs:label>
        <rdfs:label xml:lang="es">Punto de observación</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Organization -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Organization">
        <rdfs:subClassOf rdf:resource="https://schema.org/Organization"/>
        <rdfs:comment xml:lang="en">Any public or private organization that owns or manages an element of the infrastructure.</rdfs:comment>
        <rdfs:comment xml:lang="es">Cualquier organización pública o privada que sea titular o gestione un elemento de la infraestructura.</rdfs:comment>
        <rdfs:label xml:lang="es">Organización</rdfs:label>
        <rdfs:label xml:lang="en">Organization</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#UrbanElement -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#UrbanElement">
        <rdfs:subClassOf rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#InfrastructureElement"/>
        <rdfs:comment xml:lang="es">Comprende el inventario de elementos urbanos tales como señales viales, semáforos, pilonas, etc.</rdfs:comment>
        <rdfs:comment xml:lang="en">It includes the inventory of urban elements such as road signs, traffic lights, bollards, etc.</rdfs:comment>
        <rdfs:label xml:lang="es">Elemento urbano</rdfs:label>
        <rdfs:label xml:lang="en">Urban element</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Violation -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#Violation">
        <rdfs:comment xml:lang="es">Incumplimiento o violación de las normas de tránsito o acceso, leyes de circulación u ordenanzas locales por parte de una persona o de un conductor o propietario de un vehículo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Non-compliance or violation of traffic or access rules, road laws or local ordinances by a person or a driver or owner of a vehicle.</rdfs:comment>
        <rdfs:label xml:lang="es">Infracción</rdfs:label>
        <rdfs:label xml:lang="en">Violation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.geonames.org/ontology#Feature -->


    <owl:Class rdf:about="http://www.geonames.org/ontology#Feature"/>
    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature">
        <rdfs:comment xml:lang="es">Esta clase representa el tipo &quot;feature&quot; de nivel superior. Es equivalente a GFI_Feature, definida en la norma ISO 19156:2011, y es la superclase de todos los tipos de &quot;feature&quot;.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0"/>
        <rdfs:label xml:lang="en">Feature</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Geometry -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Geometry">
        <rdfs:comment xml:lang="es">La clase representa el tipo de geometría de nivel superior. Esta clase es equivalente a la clase UML GM_Object definida en la norma ISO 19107 y es la superclase de todos los tipos de geometría.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.0"/>
        <rdfs:isDefinedBy xml:lang="es">Geometría</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">Geometry</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/sf#Point -->


    <owl:Class rdf:about="http://www.opengis.net/ont/sf#Point">
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/sf#"/>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/FeatureOfInterest -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/FeatureOfInterest">
        <rdfs:comment xml:lang="es">Cosa cuya propiedad se está estimando o calculando en el curso de una Observación para llegar a un Resultado o cuya propiedad está siendo manipulada por un Actuador, o que está siendo muestreada o transformada en un acto de Muestreo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:label xml:lang="es">Entidad de interés</rdfs:label>
        <rdfs:label xml:lang="en">Feature Of Interest</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/ObservableProperty -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/ObservableProperty">
        <rdfs:comment xml:lang="es">Una cualidad observable (propiedad, característica) de una entidad de interés.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:label xml:lang="es">Propiedad observable</rdfs:label>
        <rdfs:label>Observable Property</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Observation -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Observation">
        <rdfs:comment xml:lang="es">Acto de realizar un procedimiento (de observación) para estimar o calcular el valor de una propiedad de una característica de interés. Se vincula a un sensor para describir qué realizó la observación y cómo; se vincula a una propiedad observable para describir de qué propiedad es la estimación del resultado, y a una característica de interés para detallar con qué se asoció esa propiedad.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:label xml:lang="es">Observación</rdfs:label>
        <rdfs:label>Observation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/sosa/Sensor -->


    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Sensor">
        <rdfs:comment xml:lang="es">Sistema que implementa un procedimiento de observación para determinar el valor de una Propiedad observable.Puede ser un dispositivo, una infraestructura, un agente (incluyendo humanos) o software (simulación). Un sensor responde a un estímulo, por ejemplo, un cambio en el entorno o datos de entrada compuestos por los resultados de observaciones previas.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/ns/sosa/"/>
        <rdfs:label xml:lang="en">Sensor</rdfs:label>
        <rdfs:label xml:lang="es">Sensor</rdfs:label>
    </owl:Class>
    


    <!-- https://schema.org/Organization -->


    <owl:Class rdf:about="https://schema.org/Organization">
        <rdfs:comment xml:lang="en">An organization such as a school, NGO, corporation, club, etc.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una organización como una escuela, una ONG, una corporación, un club, etc.</rdfs:comment>
        <rdfs:label xml:lang="es">Organización</rdfs:label>
        <rdfs:label xml:lang="en">Organization</rdfs:label>
    </owl:Class>
    


    <!-- 
