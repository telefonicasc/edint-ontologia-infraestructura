  } ]
}, {
  "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#nivel",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Calculado a partir de la velocidad, requiere una ecuación o unos niveles de velocidad asociados: verde, fluido; amarillo, lento; naranja, denso; rojo, congestión; negro, circulación interrumpida; gris, sin datos"
  }, {
    "@language" : "en",
    "@value" : "Calculated from the speed, it requires an equation or associated speed levels: green, fluid; yellow, slow; orange, dense; red, congestion; black, traffic interrupted; grey, no data."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "level"
  }, {
    "@language" : "es",
    "@value" : "nivel"
  } ]
}, {
  "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#numSentidos",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Number of directions of traffic"
  }, {
    "@language" : "es",
    "@value" : "Número de sentidos de circulación"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "_:genid39"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Sentidos de circulación"
  }, {
    "@language" : "en",
    "@value" : "Street directions"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#integer"
  } ]
}, {
  "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#ocupacion",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Es la ocupación del detector mientras está pasando por encima un vehículo, está asociado a detectores tipo espira electromagnética, y es el tiempo desde que el detector detecta al vehículo hasta que deja detectarlo."
  }, {
    "@language" : "en",
    "@value" : "It is the occupation of the detector while it is passing over a vehicle, it is associated with electromagnetic loop type detectors, and it is the time from when the detector detects the vehicle until it allows it to be detected."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "occupation"
  }, {
    "@language" : "es",
    "@value" : "ocupación"
  } ]
}, {
  "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#recurrencia",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Esta propiedad permite describir la recurrencia."
  }, {
    "@language" : "en",
    "@value" : "This property allows describing the recurrence"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaPlanificada"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Recurrence"
  }, {
    "@language" : "es",
    "@value" : "Recurrencia"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#topDataProperty"
  } ]
}, {
  "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#tipoEquipoTrafico",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#FunctionalProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Tipo de equipo de tráfico, equipos de control y dispositivos de medición"
  }, {
    "@language" : "en",
    "@value" : "Type of traffic equipment, monitor equipment or meassuring devices"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#EquipoTrafico"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Tipo de Equipo de Tráfico"
  }, {
    "@language" : "en",
    "@value" : "Type of Traffic Equipment"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "_:genid5"
  } ]
}, {
  "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#tipoIncidencia",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#FunctionalProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Tipo de incidencia, pueden ser planificadas o no planificadas."
  }, {
    "@language" : "en",
    "@value" : "Type of incidence, planned or unplannedt"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#Incidencia"
  } ],
