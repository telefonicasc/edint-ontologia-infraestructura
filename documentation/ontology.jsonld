  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "La fecha y hora prevista de\n\tfinalización de una incidencia planificada (en formato fecha ISO 8601)"
  }, {
    "@language" : "en",
    "@value" : "The end date and time of a planned incidence (in ISO 8601 date format)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#IncidenciaPlanificada"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
