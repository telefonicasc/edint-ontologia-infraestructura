    "@language" : "es",
    "@value" : "Incidencia no planificada del tráfico de una ciudad"
  }, {
    "@language" : "en",
    "@value" : "Unplanned traffic incidence"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
