  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Observación realizada por un Dispositivo de Medición de Tráfico"
  }, {
    "@language" : "en",
    "@value" : "Observation by a Traffic Measuring Device"
  } ],
