    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Tipo de Incidencia"
  }, {
    "@language" : "en",
    "@value" : "Type of Incidence"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "_:genid9"
  } ]
}, {
  "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#unidadMedida",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "En el caso del nivel del servicio, las medidas posibles son: verde o fluido; amarillo o lento; naranja o denso; rojo o congestión; negro o circulación interrumpida; gris o sin datos."
  }, {
    "@language" : "es",
    "@value" : "Esta propiedad permite describir la unidad de medida de la medición del Dispositivo de Medición de Tráfico."
  }, {
    "@language" : "en",
    "@value" : "In the case of the Service level (nivel), the possible measures are: green or fluid; yellow or slow; orange or dense; red or congestion; black or interrupted circulation; grey or no data."
  }, {
    "@language" : "en",
    "@value" : "This property allows describing the unit of measurement of the Trafic Monitoring Device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#PropiedadMedicionTrafico"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://vocab.ciudadesabiertas.es/def/transporte/trafico#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Unidad de Medida"
  }, {
    "@language" : "en",
    "@value" : "Unit of Measurement"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#topDataProperty"
  } ]
