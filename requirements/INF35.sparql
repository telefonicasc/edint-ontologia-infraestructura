
# INF35: ¿Qué infracciones (por tipo) han ocurrido en un punto concreto?

PREFIX edintinf: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#>
PREFIX sosa:     <http://www.w3.org/ns/sosa/>
PREFIX skos:     <http://www.w3.org/2004/02/skos/core#>
PREFIX rdfs:     <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?obsPoint ?obsPointLabel
       ?infraction ?infractionLabel
       ?type ?typeLabel
WHERE {

    # Punto de acceso concreto
    BIND(<URI-del-punto-de-acceso> AS ?obsPoint)
    OPTIONAL { ?obsPoint rdfs:label ?obsPointLabel . }

    # Observación realizada sobre este punto
    ?observation sosa:hasFeatureOfInterest ?obsPoint ;
                 edintinf:provesViolation ?infraction .

    OPTIONAL { ?observation rdfs:label ?obsLabel . }

    # Infracción registrada
    OPTIONAL { ?infraction rdfs:label ?infractionLabel . }

    # Tipo de infracción (concepto SKOS)
    OPTIONAL {
        ?infraction edintinf:hasViolationType ?type .
        OPTIONAL { ?type skos:prefLabel ?typeLabel . }
        OPTIONAL { ?type rdfs:label ?typeLabel . }
    }
}
ORDER BY ?typeLabel ?infraction