
INF33: ¿En qué punto de acceso se produjo una infracción concreta?
# También vale para INF34: ¿Qué acceso/observación apoya una infracción concreta?

PREFIX edintinf: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#>
PREFIX sosa:     <http://www.w3.org/ns/sosa/>
PREFIX rdfs:     <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?infraction ?infractionLabel
       ?observation ?observationLabel
       ?obsPoint ?obsPointLabel
WHERE {

    # Infracción concreta (sustituir la URI)
    BIND(<URI-de-la-infraccion> AS ?infraction)

    OPTIONAL { ?infraction rdfs:label ?infractionLabel . }

    # Observación que soporta esta infracción
    ?observation edintinf:supportsTrafficViolation ?infraction .
    OPTIONAL { ?observation rdfs:label ?observationLabel . }

    # Punto de acceso (observación) donde se produjo
    ?observation sosa:hasFeatureOfInterest ?obsPoint .
    OPTIONAL { ?obsPoint rdfs:label ?obsPointLabel . }
}

# Variante para incluir el vehículo de la infracción

PREFIX edintinf: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#>
PREFIX edintveh: <http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#>
PREFIX sosa:     <http://www.w3.org/ns/sosa/>
PREFIX rdfs:     <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?infraction ?infractionLabel
       ?observation ?observationLabel
       ?obsPoint ?obsPointLabel
       ?vehicle ?vehicleLabel
WHERE {

  # Infracción concreta (sustituir la URI)
  BIND(<URI-de-la-infraccion> AS ?infraction)
  OPTIONAL { ?infraction rdfs:label ?infractionLabel . }

  # Observación que apoya esta infracción  →  punto de acceso
  ?observation edintinf:supportsTrafficViolation ?infraction ;
               sosa:hasFeatureOfInterest ?obsPoint .
  OPTIONAL { ?observation rdfs:label ?observationLabel . }
  OPTIONAL { ?obsPoint    rdfs:label ?obsPointLabel . }

  # Vehículo: por cualquiera de los dos caminos (robusto)
  OPTIONAL {?infraction edintinf:linkedTo ?vehicle .}
  #Puede haber errores con la siguiente si la observación indluye varios vehículos
  # OPTIONAL { ?observation edintinf:includesVehicle ?vehicle . }


  OPTIONAL { ?vehicle rdfs:label ?vehicleLabel . }
}